<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión</title>
    <link rel="stylesheet" href="../css/loggim.css" />
  </head>
  <body>
    <div class="login-container">
      <div class="login-header">
        <h1>Iniciar Sesión</h1>
        <p>Ingresa tus credenciales para acceder</p>
      </div>

      <form id="loginForm" class="login-form" action="/login" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label for="username">Usuario</label>
          <input
            type="text"
            id="apodo"
            name="username"
            placeholder="Ingresa tu usuario"
            required
          />
        </div>

        <div class="form-group">
          <label for="password">Contraseña</label>
          <input
            type="password"
            id="password"
            name="password"
            placeholder="Ingresa tu contraseña"
            required
          />
          <span class="toggle-password" id="toggle-password-btn">👁️</span>
        </div>

        <div class="form-options" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1em;">
          <label style="display: flex; align-items: center; gap: 5px;"> <input type="checkbox" name="remember" /> Recordarme </label>
          <a href="/recuperar" style="font-size: 0.9em; color: #10b981; text-decoration: none; font-weight: 600;">¿Olvidaste tu contraseña?</a>
        </div>

        <button type="submit" class="login-btn">Ingresar</button>

        <div class="register-link">
          ¿No tienes cuenta? <a href="/registro">Regístrate aquí</a>
        </div>

        <div class="register-link" style="margin-top: 12px; border-top: 1px dashed #eee; padding-top: 12px; font-size: 0.9em;">
          ¿Eres administrador? <a href="/admin-login" style="color: #10b981; font-weight: bold;">Acceso Administrativo</a>
        </div>

        <div class="container-back-index">
          <a href="/"> Volver a la pagina Principal </a>
        </div>
      </form>
    </div>
    <script src="../js/loggim.js"></script>
    <script src="../js/main.js"></script>
  </body>
  <!-- Loader global -->
  <div id="global-loader" style="display: none">
    <div class="loader-backdrop"></div>
    <div class="loader-spinner">
      <i id="loader-icon" class="fa fa-spinner fa-spin fa-3x"></i>
      <p id="loader-text">Cargando...</p>
    </div>
  </div>
</html>
