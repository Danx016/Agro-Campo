<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Consola de Despacho Vendedor - Agro-Campo</title>
    <!-- Google Fonts & FontAwesome -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="../css/style.css" />
    <link rel="stylesheet" href="../css/perfil.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
      :root {
        --emerald-primary: #10b981;
        --emerald-dark: #047857;
        --emerald-light: #ecfdf5;
        --slate-bg: #f8fafc;
        --card-bg: #ffffff;
        --border-color: #e2e8f0;
        --text-main: #0f172a;
        --text-muted: #64748b;
        --pending: #f59e0b;
        --dispatched: #10b981;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Outfit', sans-serif;
      }

      body {
        background: linear-gradient(rgba(248, 250, 252, 0.85), rgba(248, 250, 252, 0.95)), url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1600&q=80') center/cover fixed;
        color: var(--text-main);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* Navbar */
      .navbar {
        background: linear-gradient(135deg, #1b4332 0%, #081c15 100%);
        color: white;
        padding: 0.85rem 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
        position: sticky;
        top: 0;
        z-index: 1000;
        border-bottom: 2.5px solid rgba(16, 185, 129, 0.35);
        backdrop-filter: blur(10px);
      }

      .nav-logo {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .nav-logo i {
        font-size: 1.6rem;
        color: #10b981;
        filter: drop-shadow(0 0 8px rgba(16, 185, 129, 0.4));
      }

      .nav-logo span {
        font-weight: 800;
        font-size: 1.35rem;
        letter-spacing: -0.5px;
        background: linear-gradient(135deg, #ffffff 0%, #a7f3d0 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .nav-user {
        display: flex;
        align-items: center;
        gap: 15px;
      }

      .badge-seller {
        background-color: rgba(16, 185, 129, 0.25) !important;
        color: #a7f3d0 !important;
        border: 1px solid rgba(16, 185, 129, 0.3) !important;
        padding: 6px 14px !important;
        border-radius: 50px !important;
        font-size: 0.82rem !important;
        font-weight: 700 !important;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }

      .btn-logout {
        background-color: rgba(239, 68, 68, 0.15);
        color: #fca5a5;
        border: 1px solid rgba(239, 68, 68, 0.3);
        padding: 8px 16px;
        border-radius: 30px;
        font-weight: 700;
        font-size: 0.88rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all 0.25s ease;
        text-decoration: none;
      }

      .btn-logout:hover {
        background-color: #ef4444;
        color: white;
        box-shadow: 0 0 12px rgba(239, 68, 68, 0.45);
        transform: translateY(-1px);
      }

      /* Main container */
      .container {
        max-width: 1200px;
        width: 95%;
        margin: 40px auto;
        flex: 1;
      }

      .dashboard-header {
        margin-bottom: 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
      }

      .dashboard-title h2 {
        font-size: 1.8rem;
        font-weight: 700;
        color: #065f46;
      }

      .dashboard-title p {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin-top: 4px;
      }

      /* Stats Dashboard */
      .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
        width: 100%;
      }
      .stat-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.03);
        border: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        gap: 15px;
      }
      .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
      }
      .stat-icon.blue { background: #e0f2fe; color: #0284c7; }
      .stat-icon.yellow { background: #fef3c7; color: #d97706; }
      .stat-icon.green { background: #dcfce7; color: #15803d; }
      .stat-icon.red { background: #fee2e2; color: #b91c1c; }
      .stat-info h3 { font-size: 1.4rem; font-weight: 700; color: var(--text-main); margin-bottom: 2px; }
      .stat-info p { font-size: 0.85rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; }

      .btn-cancel {
        background-color: white;
        color: #ef4444;
        border: 1px solid #ef4444;
        padding: 10px 15px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
      }
      .btn-cancel:hover {
        background-color: #fef2f2;
      }
      .btn-print {
        background-color: #f1f5f9;
        color: #475569;
        border: 1px solid #cbd5e1;
        padding: 10px 15px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
      }
      .btn-print:hover {
        background-color: #e2e8f0;
      }
      .status-badge.canceled {
        background-color: #fef2f2;
        color: #b91c1c;
        border: 1px solid #fecaca;
      }

      /* Tab and Filter Section */
      .filters-row {
        background: white;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 15px 20px;
        margin-bottom: 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.02);
      }

      .tabs-group {
        display: flex;
        gap: 10px;
      }

      .tab-btn {
        background: none;
        border: none;
        padding: 8px 16px;
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--text-muted);
        cursor: pointer;
        border-radius: 8px;
        transition: all 0.2s;
      }

      .tab-btn.active {
        background-color: var(--emerald-light);
        color: var(--emerald-dark);
      }

      .search-box {
        position: relative;
        max-width: 300px;
        width: 100%;
      }

      .search-box i {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
      }

      .search-box input {
        width: 100%;
        padding: 8px 12px 8px 35px;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        font-size: 0.9rem;
        outline: none;
        transition: border-color 0.2s;
      }

      .search-box input:focus {
        border-color: var(--emerald-primary);
      }

      /* Orders Grid Layout */
      .orders-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 25px;
      }

      .order-card {
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
        transition: transform 0.2s, box-shadow 0.2s;
        overflow: hidden;
      }

      .order-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
      }

      .order-card-header {
        background-color: #fafbfc;
        border-bottom: 1px solid var(--border-color);
        padding: 15px 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
      }

      .order-meta {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
      }

      .order-id {
        font-weight: 700;
        color: var(--emerald-dark);
        font-size: 1.1rem;
      }

      .order-date {
        color: var(--text-muted);
        font-size: 0.9rem;
      }

      .status-badge {
        font-size: 0.75rem;
        font-weight: 700;
        padding: 5px 12px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
      }

      .status-badge.pending {
        background-color: #fffbeb;
        color: #b45309;
        border: 1px solid #fde68a;
      }

      .status-badge.dispatched {
        background-color: #ecfdf5;
        color: #047857;
        border: 1px solid #a7f3d0;
      }

      /* Card Content */
      .order-card-body {
        padding: 25px;
      }

      .client-details {
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 1px solid #f1f5f9;
      }

      .client-name {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-main);
      }

      .client-email {
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-top: 2px;
      }

      /* Items Table */
      .items-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 20px;
        font-size: 0.9em;
      }

      .items-table th {
        color: var(--text-muted);
        font-weight: 600;
        text-align: left;
        padding: 8px 12px;
        border-bottom: 2px solid var(--border-color);
      }

      .items-table td {
        padding: 10px 12px;
        border-bottom: 1px solid #f1f5f9;
      }

      .product-total {
        font-weight: 600;
        text-align: right;
      }

      /* Totals and Actions Footer */
      .order-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        padding-top: 15px;
        border-top: 1px solid #f1f5f9;
      }

      .order-total-block {
        font-size: 1.05rem;
      }

      .order-total-block span {
        color: var(--text-muted);
        font-size: 0.9rem;
      }

      .order-total-price {
        font-weight: 700;
        color: #047857;
        font-size: 1.25rem;
        margin-top: 2px;
      }

      .btn-dispatch {
        background-color: var(--emerald-primary);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        box-shadow: 0 4px 10px rgba(16, 185, 129, 0.2);
      }

      .btn-dispatch:hover {
        background-color: var(--emerald-dark);
        box-shadow: 0 6px 15px rgba(4, 120, 87, 0.3);
      }

      .btn-dispatched-complete {
        background-color: #f1f5f9;
        color: #94a3b8;
        border: 1px solid #e2e8f0;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: not-allowed;
      }

      /* Empty & Loading states */
      .loading-state, .empty-state {
        background: white;
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 50px;
        text-align: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.01);
      }

      .empty-state i {
        font-size: 3rem;
        color: #cbd5e1;
        margin-bottom: 15px;
      }

      .empty-state h3 {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-main);
        margin-bottom: 5px;
      }

      .empty-state p {
        color: var(--text-muted);
        font-size: 0.95rem;
      }

      /* Footer copyright */
      .footer {
        background-color: white;
        border-top: 1px solid var(--border-color);
        text-align: center;
        padding: 20px;
        color: var(--text-muted);
        font-size: 0.85rem;
        margin-top: 40px;
      }

      /* Global loader styling */
      #global-loader {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .loader-backdrop {
        position: absolute;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(4px);
      }
      .loader-spinner {
        position: relative;
        z-index: 10000;
        text-align: center;
        color: var(--emerald-primary);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        background: #ffffff;
        padding: 2.2rem 2.8rem;
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        min-width: 260px;
        border-top: 5px solid var(--emerald-primary);
      }
      .loader-spinner i {
        margin: 0;
      }
      .loader-spinner p {
        margin: 0;
        font-weight: 600;
        color: #333333;
        font-size: 1.05em;
        line-height: 1.4;
      }

      /* Estilos para impresión de la guía de despacho */
      #print-guide-container {
        display: none;
      }

      @media print {
        /* Ocultar absolutamente todo el panel administrativo de Agro-Campo */
        body * {
          display: none !important;
        }
        
        /* Mostrar única y exclusivamente el contenedor de la guía de despacho */
        #print-guide-container,
        #print-guide-container * {
          display: block !important;
        }

        #print-guide-container {
          display: block !important;
          position: absolute;
          left: 0;
          top: 0;
          width: 100%;
          margin: 0;
          padding: 0;
          background: white;
          color: #1e293b;
        }
        
        /* Asegurar la correcta disposición en tablas durante la impresión */
        #print-guide-container table {
          display: table !important;
          width: 100% !important;
        }
        #print-guide-container thead {
          display: table-header-group !important;
        }
        #print-guide-container tbody {
          display: table-row-group !important;
        }
        #print-guide-container tr {
          display: table-row !important;
        }
        #print-guide-container th,
        #print-guide-container td {
          display: table-cell !important;
        }
      }
    </style>
  </head>
  <body>
    <!-- Contenedor exclusivo para impresión de guías de despacho -->
    <div id="print-guide-container"></div>

    <!-- CSRF Token Input -->
    <input type="hidden" id="csrfToken" value="<%= csrfToken %>" />

    <!-- Navbar -->
    <header class="navbar">
      <div class="nav-logo">
        <i class="fa fa-truck-ramp-box"></i>
        <span>AGRO-CAMPO DESPACHOS</span>
      </div>
      <div class="nav-user" style="display: flex; align-items: center; gap: 15px;">
        <a href="/perfil-vendedor" style="text-decoration: none;">
          <div class="despachador-nav-profile" style="display: flex; align-items: center; gap: 10px;">
            <img id="nav-despachador-avatar" src="../img/logo vaca.png" alt="Avatar" style="width: 35px; height: 35px; border-radius: 50%; object-fit: cover; border: 2px solid #10b981; box-shadow: 0 0 10px rgba(16,185,129,0.25);">
            <div style="display: flex; flex-direction: column; text-align: left; line-height: 1.2;">
              <span id="seller-name-label" style="font-weight: 700; color: white; font-size: 0.92em;">Cargando...</span>
              <span style="font-size: 0.72em; font-weight: 800; color: #a7f3d0; text-transform: uppercase; letter-spacing: 0.5px;">Despachador</span>
            </div>
          </div>
        </a>
        <a href="/logout" class="btn-logout" id="logout-btn">
          <i class="fa fa-sign-out-alt"></i> Salir
        </a>
      </div>
    </header>

    <!-- Main Container -->
    <main class="container">
      <div class="dashboard-header">
        <div class="dashboard-title">
          <h2>Consola de Gestión de Pedidos</h2>
          <p>Supervisa, administra y despacha las compras realizadas en tiempo real. Actualización automática activa.</p>
        </div>
      </div>
      
      <!-- Stats Dashboard -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon green"><i class="fa fa-dollar-sign"></i></div>
          <div class="stat-info">
            <h3 id="stat-revenue">$0.00</h3>
            <p>Ingresos del Mes</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon blue"><i class="fa fa-receipt"></i></div>
          <div class="stat-info">
            <h3 id="stat-recepcion">0</h3>
            <p>Recepción</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon yellow"><i class="fa fa-box-open"></i></div>
          <div class="stat-info">
            <h3 id="stat-preparacion">0</h3>
            <p>Preparación</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon green"><i class="fa fa-truck"></i></div>
          <div class="stat-info">
            <h3 id="stat-transito">0</h3>
            <p>Tránsito</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon red"><i class="fa fa-triangle-exclamation"></i></div>
          <div class="stat-info">
            <h3 id="stat-novedades">0</h3>
            <p>Novedades</p>
          </div>
        </div>
      </div>

      <!-- Filters & Tabs Row -->
      <div class="filters-row">
        <div class="tabs-group">
          <button class="tab-btn active" id="tab-all">Todos los Pedidos</button>
          <button class="tab-btn" id="tab-recepcion">Recepción</button>
          <button class="tab-btn" id="tab-preparacion">Preparación</button>
          <button class="tab-btn" id="tab-transito">Tránsito</button>
          <button class="tab-btn" id="tab-novedades">Novedades</button>
        </div>
        <div class="search-box">
          <i class="fa fa-search"></i>
          <input type="text" id="search-input" placeholder="Buscar por cliente o nº..." />
        </div>
      </div>

      <!-- Orders Container -->
      <div id="orders-container" class="orders-grid">
        <!-- Spinner Loading Inicial -->
        <div class="loading-state" id="loading-indicator">
          <i class="fa fa-spinner fa-spin fa-3x" style="color: var(--emerald-primary);"></i>
          <p style="margin-top: 15px; font-weight: 600; color: var(--text-muted);">Cargando registros de compras del servidor...</p>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
      <p>© 2026 Agro-Campo S.A.S. Portal de Despachos y Logística del Campo. Todos los derechos reservados.</p>
    </footer>

    <!-- Loader Global -->
    <div id="global-loader" style="display: none">
      <div class="loader-backdrop"></div>
      <div class="loader-spinner">
        <i id="loader-icon" class="fa fa-spinner fa-spin fa-3x"></i>
        <p id="loader-text">Procesando despacho en la base de datos...</p>
      </div>
    </div>

    <!-- Client-side script handling data fetch and UI renders -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        // 1. Verificar sesión de vendedor en el navegador
        const user = JSON.parse(localStorage.getItem("user"));
        if (!user || (user.rolUser !== 2 && user.rolUser !== 1 && user.username !== 'admin')) {
          alert("Acceso denegado. Se requieren credenciales de vendedor o administrador.");
          window.location.href = "/login";
          return;
        }

        // Mostrar nombre del despachador en el navbar
        document.getElementById("seller-name-label").textContent = user.nombreUser || user.username;

        const authHeaders = {
          "Content-Type": "application/json"
        };
        if (user.token) {
          authHeaders["Authorization"] = `Bearer ${user.token}`;
        }
const VENDEDOR_STATUS_MAP = {
  "Pedido recibido": { icon: "fa-receipt", color: "#3b82f6" },
  "Pago confirmado": { icon: "fa-circle-check", color: "#10b981" },
  "Pedido en preparación": { icon: "fa-box-open", color: "#f59e0b" },
  "Pedido empacado": { icon: "fa-box", color: "#6366f1" },
  "Pedido enviado": { icon: "fa-truck-ramp-box", color: "#06b6d4" },
  "Producto en tránsito": { icon: "fa-truck", color: "#0284c7" },
  "Producto llegó a centro logístico": { icon: "fa-warehouse", color: "#db2777" },
  "Pedido en ruta de entrega": { icon: "fa-motorcycle", color: "#ca8a04" },
  "Entrega exitosa": { icon: "fa-house-circle-check", color: "#10b981" },
  "Entrega fallida": { icon: "fa-triangle-exclamation", color: "#ef4444" },
  "Retraso en envío": { icon: "fa-clock", color: "#f97316" },
  "Producto cancelado": { icon: "fa-circle-xmark", color: "#64748b" },
  "Devolución iniciada": { icon: "fa-rotate-left", color: "#a855f7" },
  "Reembolso procesado": { icon: "fa-hand-holding-dollar", color: "#14b8a6" }
};

        let allOrders = [];
        let activeFilter = 'all'; // 'all', 'pending', 'dispatched'

        const ordersContainer = document.getElementById("orders-container");
        const searchInput = document.getElementById("search-input");
        const loader = document.getElementById("global-loader");

        // 2. Traer todos los pedidos desde el backend
        async function fetchAllOrders() {
          try {
            const response = await fetch("/api/compra/todas", {
              method: "GET",
              headers: authHeaders
            });

            if (response.ok) {
              allOrders = await response.json();
              renderOrders();
            } else {
              ordersContainer.innerHTML = `
                <div class="empty-state">
                  <i class="fa fa-triangle-exclamation" style="color: #ef4444;"></i>
                  <h3>Error de Carga</h3>
                  <p>No se pudieron recuperar las compras del servidor. Inténtalo de nuevo.</p>
                </div>
              `;
            }
          } catch (err) {
            console.error("Error al obtener pedidos:", err);
            ordersContainer.innerHTML = `
              <div class="empty-state">
                <i class="fa fa-wifi" style="color: #ef4444;"></i>
                <h3>Error de Red</h3>
                <p>Comprueba tu conexión e inténtalo de nuevo.</p>
              </div>
            `;
          }
        }

        // 3. Renderizar las tarjetas de pedidos
        function renderOrders() {
          const query = searchInput.value.trim().toLowerCase();
          
          let totalRevenue = 0;
          let recepcionCount = 0;
          let preparacionCount = 0;
          let transitoCount = 0;
          let novedadesCount = 0;

          // Calcular estadísticas de manera robusta mapeando los 14 estados
          allOrders.forEach(order => {
            const status = order.estado || "Pedido recibido";
            const s = status.toLowerCase();
            
            const isRecepcion = ["pedido recibido", "pago confirmado", "pendiente"].includes(s);
            const isPreparacion = ["pedido en preparación", "pedido empacado"].includes(s);
            const isTransito = ["pedido enviado", "producto en tránsito", "producto llegó a centro logístico", "pedido en ruta de entrega", "entrega exitosa", "despachado"].includes(s);
            const isNovedades = ["producto cancelado", "entrega fallida", "retraso en envío", "devolución iniciada", "reembolso procesado", "cancelado"].includes(s);

            if (isTransito) totalRevenue += parseFloat(order.total);

            if (isRecepcion) recepcionCount++;
            else if (isPreparacion) preparacionCount++;
            else if (isTransito) transitoCount++;
            else if (isNovedades) novedadesCount++;
          });

          document.getElementById('stat-revenue').textContent = '$' + totalRevenue.toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
          if (document.getElementById('stat-recepcion')) document.getElementById('stat-recepcion').textContent = recepcionCount;
          if (document.getElementById('stat-preparacion')) document.getElementById('stat-preparacion').textContent = preparacionCount;
          if (document.getElementById('stat-transito')) document.getElementById('stat-transito').textContent = transitoCount;
          if (document.getElementById('stat-novedades')) document.getElementById('stat-novedades').textContent = novedadesCount;

          // Filtrar según pestaña activa y búsqueda de texto
          const filtered = allOrders.filter(order => {
            const status = order.estado || "Pedido recibido";
            const s = status.toLowerCase();
            
            const isRecepcion = ["pedido recibido", "pago confirmado", "pendiente"].includes(s);
            const isPreparacion = ["pedido en preparación", "pedido empacado"].includes(s);
            const isTransito = ["pedido enviado", "producto en tránsito", "producto llegó a centro logístico", "pedido en ruta de entrega", "entrega exitosa", "despachado"].includes(s);
            const isNovedades = ["producto cancelado", "entrega fallida", "retraso en envío", "devolución iniciada", "reembolso procesado", "cancelado"].includes(s);

            // Filtro de pestaña
            if (activeFilter === 'recepcion' && !isRecepcion) return false;
            if (activeFilter === 'preparacion' && !isPreparacion) return false;
            if (activeFilter === 'transito' && !isTransito) return false;
            if (activeFilter === 'novedades' && !isNovedades) return false;

            // Filtro de búsqueda (ID de orden o Nombre de cliente)
            if (query) {
              const matchesId = order.id_compra.toString().includes(query);
              const matchesName = order.nombre_cliente.toLowerCase().includes(query);
              return matchesId || matchesName;
            }

            return true;
          });

          // Si no hay pedidos tras aplicar filtros
          if (filtered.length === 0) {
            ordersContainer.innerHTML = `
              <div class="empty-state">
                <i class="fa fa-box-open"></i>
                <h3>No se encontraron pedidos</h3>
                <p>No hay compras registradas en esta sección que coincidan con la búsqueda.</p>
              </div>
            `;
            return;
          }

          ordersContainer.innerHTML = "";

          filtered.forEach(order => {
            const fechaStr = new Date(order.fecha).toLocaleDateString('es-ES', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
              hour: '2-digit',
              minute: '2-digit'
            });

            // Normalizar el estado
            let currentStatus = order.estado || "Pedido recibido";
            if (currentStatus === "Pendiente") currentStatus = "Pedido recibido";
            if (currentStatus === "Despachado") currentStatus = "Pedido enviado";

            const statusInfo = VENDEDOR_STATUS_MAP[currentStatus] || { icon: "fa-box", color: "#64748b" };
            
            // Compilar las filas de los productos comprados
            let itemsRows = "";
            order.detalles.forEach(item => {
              const itemTotal = parseFloat(item.cantidad * item.precio_unitario).toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
              itemsRows += `
                <tr>
                  <td style="padding: 10px 12px; font-weight: 500;">${item.nombre_producto}</td>
                  <td style="padding: 10px 12px; text-align: center; color: var(--text-muted);">${item.cantidad} kg</td>
                  <td style="padding: 10px 12px; text-align: right; color: var(--text-muted);">$${parseFloat(item.precio_unitario).toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}</td>
                  <td class="product-total">$${itemTotal}</td>
                </tr>
              `;
            });

            let optionsHtml = "";
            const STATUS_GROUPS = {
              "Recepción y Pago": ["Pedido recibido", "Pago confirmado"],
              "Preparación": ["Pedido en preparación", "Pedido empacado"],
              "Tránsito y Entrega": ["Pedido enviado", "Producto en tránsito", "Producto llegó a centro logístico", "Pedido en ruta de entrega", "Entrega exitosa"],
              "Novedades y Devoluciones": ["Entrega fallida", "Retraso en envío", "Producto cancelado", "Devolución iniciada", "Reembolso procesado"]
            };

            Object.entries(STATUS_GROUPS).forEach(([groupName, statuses]) => {
              optionsHtml += `<optgroup label="${groupName}">`;
              statuses.forEach(statusOpt => {
                const isSelected = statusOpt.toLowerCase() === currentStatus.toLowerCase() ? "selected" : "";
                optionsHtml += `<option value="${statusOpt}" ${isSelected}>${statusOpt}</option>`;
              });
              optionsHtml += `</optgroup>`;
            });

            const actionButtons = `
              <div style="display: flex; align-items: center; gap: 8px;">
                <label style="font-size: 0.85rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase;">Estado:</label>
                <select class="change-status-vendedor-select" data-id="${order.id_compra}" style="padding: 8px 12px; border-radius: 8px; border: 1.5px solid #cbd5e1; background-color: white; font-weight: 700; cursor: pointer; color: #1e293b; font-size: 0.85em; outline: none; transition: all 0.2s; box-shadow: 0 1px 2px rgba(0,0,0,0.05); font-family: inherit;">
                  ${optionsHtml}
                </select>
              </div>
            `;

            // Tarjeta HTML de cada pedido
            const card = `
              <div class="order-card" id="order-card-${order.id_compra}">
                <div class="order-card-header">
                  <div class="order-meta">
                     <span class="order-id">Pedido #${order.id_compra}</span>
                     <span class="order-date"><i class="fa fa-calendar-days"></i> ${fechaStr}</span>
                  </div>
                  <span class="status-badge" style="background-color: ${statusInfo.color}15; color: ${statusInfo.color}; border: 1.5px solid ${statusInfo.color}35;">
                    <i class="fa ${statusInfo.icon}"></i>
                    ${currentStatus}
                  </span>
                </div>
                
                <div class="order-card-body">
                  <div class="client-details">
                    <div class="client-name"><i class="fa fa-user" style="color: var(--emerald-dark); margin-right: 6px;"></i> ${order.nombre_cliente}</div>
                    <div class="client-email"><i class="fa fa-envelope" style="margin-right: 6px;"></i> ${order.correo_cliente}</div>
                    <div class="client-address" style="margin-top: 5px; color: #475569; font-size: 0.9em;">
                      <i class="fa fa-map-marker-alt" style="color: #ef4444; margin-right: 6px;"></i> 
                      <strong>Dirección de Envío:</strong> ${order.direccion_envio || 'No especificada'}
                    </div>
                  </div>

                  <table class="items-table">
                    <thead>
                      <tr>
                        <th>Producto</th>
                        <th style="text-align: center;">Cantidad</th>
                        <th style="text-align: right;">Precio Unit.</th>
                        <th style="text-align: right;">Total</th>
                      </tr>
                    </thead>
                    <tbody>
                      ${itemsRows}
                    </tbody>
                  </table>

                  <div class="order-card-footer">
                    <div class="order-total-block">
                      <span>Total Neto Cobrado</span>
                      <div class="order-total-price">$${parseFloat(order.total).toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}</div>
                    </div>
                    
                    <div style="display: flex; gap: 10px; align-items: center;">
                      <button class="btn-print" onclick="printShippingGuide(${order.id_compra})"><i class="fa fa-print"></i> Imprimir Guía</button>
                      ${actionButtons}
                    </div>
                  </div>
                </div>
              </div>
            `;

            ordersContainer.insertAdjacentHTML("beforeend", card);
          });

          // Asignar listeners a los selects de cambio de estado
          document.querySelectorAll(".change-status-vendedor-select").forEach(select => {
            select.addEventListener("change", function() {
              const idCompra = this.getAttribute("data-id");
              const nuevoEstado = this.value;
              updateOrderStatus(idCompra, nuevoEstado);
            });
          });
        }

        // Definir la función para imprimir una guía de envío individual e industrial
        function printShippingGuide(orderId) {
          const order = allOrders.find(o => o.id_compra == orderId);
          if (!order) {
            alert("No se encontró la información de este pedido.");
            return;
          }

          const itemsRows = order.detalles.map(item => `
            <tr style="display: table-row !important;">
              <td style="padding: 12px 14px; font-weight: 600; font-size: 15px; border-bottom: 1px solid #cbd5e1; display: table-cell !important;">${item.nombre_producto}</td>
              <td style="padding: 12px 14px; text-align: center; font-weight: 700; font-size: 15px; border-bottom: 1px solid #cbd5e1; display: table-cell !important;">${item.cantidad} kg</td>
            </tr>
          `).join('');

          const printHtml = `
            <div style="font-family: 'Outfit', sans-serif; padding: 25px; color: #1e293b; background: #fff; max-width: 650px; margin: 0 auto; border: 3px solid #1e293b; border-radius: 12px; box-sizing: border-box; text-align: left;">
              <!-- Cabecera de la Guía -->
              <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px dashed #cbd5e1; padding-bottom: 20px; margin-bottom: 20px; width: 100%;">
                <div>
                  <h1 style="font-size: 26px; font-weight: 800; color: #1b4332; margin: 0 0 5px 0; letter-spacing: -0.5px;">AGRO-CAMPO</h1>
                  <p style="font-size: 13px; color: #64748b; margin: 0; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Tienda Agropecuaria & Ganadera</p>
                </div>
                <div style="text-align: right;">
                  <h2 style="font-size: 20px; font-weight: 800; color: #1e293b; margin: 0 0 5px 0; letter-spacing: -0.5px;">GUÍA DE DESPACHO</h2>
                  <span style="font-size: 13px; color: #64748b; font-weight: 600;">Pedido #${order.id_compra}</span>
                </div>
              </div>

              <!-- Sección del Destinatario -->
              <div style="font-size: 13px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: #0f766e; border-bottom: 2px solid #e2e8f0; padding-bottom: 6px; margin-bottom: 12px; margin-top: 20px;">
                Destinatario
              </div>
              
              <div style="background: #f8fafc; border: 2px solid #e2e8f0; border-radius: 8px; padding: 20px; margin-bottom: 20px;">
                <table style="width: 100%; border-collapse: collapse; display: table !important;">
                  <tr style="display: table-row !important;">
                    <td style="padding: 6px 0; vertical-align: top; font-size: 15px; width: 110px; font-weight: 800; color: #475569; text-transform: uppercase; font-size: 12px; letter-spacing: 0.5px; display: table-cell !important;">Cliente:</td>
                    <td style="padding: 6px 0; vertical-align: top; font-size: 15px; color: #1b4332; font-weight: 700; font-size: 16px; display: table-cell !important;">${order.nombre_cliente}</td>
                  </tr>
                  <tr style="display: table-row !important;">
                    <td style="padding: 6px 0; vertical-align: top; font-size: 15px; width: 110px; font-weight: 800; color: #475569; text-transform: uppercase; font-size: 12px; letter-spacing: 0.5px; display: table-cell !important;">Contacto:</td>
                    <td style="padding: 6px 0; vertical-align: top; font-size: 15px; color: #0f172a; font-weight: 500; display: table-cell !important;">${order.correo_cliente}</td>
                  </tr>
                  <tr style="display: table-row !important;">
                    <td style="padding: 10px 0 6px 0; vertical-align: top; font-size: 15px; width: 110px; font-weight: 800; color: #475569; text-transform: uppercase; font-size: 12px; letter-spacing: 0.5px; display: table-cell !important;">Entregar en:</td>
                    <td style="padding: 10px 0 6px 0; vertical-align: top; color: #0f172a; font-size: 18px !important; font-weight: 800 !important; line-height: 1.45; display: table-cell !important;">
                      📍 ${order.direccion_envio || 'No especificada'}
                    </td>
                  </tr>
                </table>
              </div>

              <!-- Detalle de Productos -->
              <div style="font-size: 13px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: #0f766e; border-bottom: 2px solid #e2e8f0; padding-bottom: 6px; margin-bottom: 12px; margin-top: 20px;">
                Contenido del Envío
              </div>
              
              <table style="width: 100%; border-collapse: collapse; margin-bottom: 25px; display: table !important;">
                <thead>
                  <tr style="display: table-row !important;">
                    <th style="text-align: left; font-size: 12px; font-weight: 800; text-transform: uppercase; color: #475569; border-bottom: 2px solid #1e293b; padding: 8px 12px; letter-spacing: 0.5px; display: table-cell !important;">Producto</th>
                    <th style="text-align: center; width: 120px; font-size: 12px; font-weight: 800; text-transform: uppercase; color: #475569; border-bottom: 2px solid #1e293b; padding: 8px 12px; letter-spacing: 0.5px; display: table-cell !important;">Cantidad</th>
                  </tr>
                </thead>
                <tbody style="display: table-row-group !important;">
                  ${itemsRows}
                </tbody>
              </table>

              <!-- Sección Industrial de Control de Despacho -->
              <div style="display: flex; justify-content: space-between; align-items: center; border-top: 2px dashed #cbd5e1; padding-top: 25px; margin-top: 25px; width: 100%;">
                <div>
                  <div style="font-family: monospace; background: #1e293b; color: white; padding: 15px 30px; border-radius: 6px; letter-spacing: 6px; font-size: 20px; font-weight: bold; display: inline-block;">
                    ||||| | |||| || ||| ||
                  </div>
                  <p style="font-size: 12px; color: #64748b; margin: 6px 0 0 0; text-align: center; font-weight: 700; letter-spacing: 1px;">
                    REF-${order.id_compra}-${Date.now().toString().slice(-6)}
                  </p>
                </div>
                
                <div style="width: 90px; height: 90px; border: 2px solid #1e293b; border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 11px; font-weight: 800; color: #1e293b; text-align: center; padding: 5px; background: #f8fafc; box-sizing: border-box;">
                  <span style="font-size: 24px; margin-bottom: 4px; color: #1b4332;">■</span>
                  AGRO-CAMPO
                </div>
              </div>
            </div>
          `;

          // Inyectar el HTML de la guía en el contenedor especial para impresión
          const container = document.getElementById("print-guide-container");
          container.innerHTML = printHtml;

          // Disparar la impresión nativa directamente
          window.print();
        }

        // Hacer la función accesible globalmente para los botones generados dinámicamente
        window.printShippingGuide = printShippingGuide;

        // 4. Hacer petición PUT para cambiar estado de pedido
        async function updateOrderStatus(idCompra, estado) {
          let mensajeConf = "";
          if (estado === "Producto cancelado" || estado === "Entrega fallida" || estado === "Devolución iniciada") {
            mensajeConf = `¿Seguro que deseas marcar el Pedido #${idCompra} como "${estado}"?`;
          } else {
            mensajeConf = `¿Seguro que deseas cambiar el estado del Pedido #${idCompra} a "${estado}"?`;
          }

          if (!(await confirm(mensajeConf))) {
            // Restore previous selected value in the dropdown visually if they cancel
            renderOrders(); 
            return;
          }

          if (loader) {
            loader.style.display = "flex";
            const loaderIcon = document.getElementById("loader-icon");
            const loaderText = document.getElementById("loader-text");
            if (loaderIcon) {
              loaderIcon.className = "fa fa-spinner fa-spin fa-3x";
              loaderIcon.style.color = "var(--emerald-primary)";
            }
            if (loaderText) {
              loaderText.textContent = `Actualizando estado a "${estado}"...`;
              loaderText.style.color = "";
            }
          }

          const csrfToken = document.getElementById("csrfToken").value;

          try {
            const response = await fetch(`/api/compra/${idCompra}/estado`, {
              method: "PUT",
              headers: {
                ...authHeaders,
                "x-csrf-token": csrfToken
              },
              body: JSON.stringify({ estado: estado })
            });

            const data = await response.json();
            const loaderIcon = document.getElementById("loader-icon");
            const loaderText = document.getElementById("loader-text");

            if (response.ok) {
              if (loaderIcon) {
                loaderIcon.className = "fa-solid fa-circle-check fa-3x";
                loaderIcon.style.color = "#10b981";
              }
              if (loaderText) {
                loaderText.textContent = data.message || "¡Estado actualizado exitosamente!";
                loaderText.style.color = "#10b981";
              }
              
              // Actualizar el estado localmente sin refrescar para mejor UX
              const orderIndex = allOrders.findIndex(o => o.id_compra == idCompra);
              if (orderIndex !== -1) {
                allOrders[orderIndex].estado = estado;
              }
              renderOrders();

              setTimeout(() => {
                if (loader) loader.style.display = "none";
              }, 2200);
            } else {
              if (loaderIcon) {
                loaderIcon.className = "fa-solid fa-circle-xmark fa-3x";
                loaderIcon.style.color = "#ef4444";
              }
              if (loaderText) {
                loaderText.textContent = data.error || "Hubo un error al actualizar el estado.";
                loaderText.style.color = "#ef4444";
              }
              setTimeout(() => {
                if (loader) loader.style.display = "none";
                renderOrders(); // Re-render to revert the select value visually
              }, 2500);
            }
          } catch (err) {
            console.error("Error de red al actualizar:", err);
            const loaderIcon = document.getElementById("loader-icon");
            const loaderText = document.getElementById("loader-text");
            if (loaderIcon) {
              loaderIcon.className = "fa-solid fa-circle-xmark fa-3x";
              loaderIcon.style.color = "#ef4444";
            }
            if (loaderText) {
              loaderText.textContent = "Error de red al intentar conectar con el servidor.";
              loaderText.style.color = "#ef4444";
            }
            setTimeout(() => {
              if (loader) loader.style.display = "none";
              renderOrders(); // Re-render to revert the select value visually
            }, 2500);
          }
        }

        // 5. Manejar cambio de pestañas de filtrado
        const tabAll = document.getElementById("tab-all");
        const tabRecepcion = document.getElementById("tab-recepcion");
        const tabPreparacion = document.getElementById("tab-preparacion");
        const tabTransito = document.getElementById("tab-transito");
        const tabNovedades = document.getElementById("tab-novedades");

        const searchBox = document.querySelector(".search-box");
        const statsGrid = document.querySelector(".stats-grid");

        function resetTabs() {
          if (tabAll) tabAll.classList.remove("active");
          if (tabRecepcion) tabRecepcion.classList.remove("active");
          if (tabPreparacion) tabPreparacion.classList.remove("active");
          if (tabTransito) tabTransito.classList.remove("active");
          if (tabNovedades) tabNovedades.classList.remove("active");

          if (ordersContainer) ordersContainer.style.display = "grid";
          if (searchBox) searchBox.style.display = "block";
          if (statsGrid) statsGrid.style.display = "grid";
        }

        if (tabAll) {
          tabAll.addEventListener("click", () => {
            resetTabs();
            tabAll.classList.add("active");
            activeFilter = 'all';
            renderOrders();
          });
        }

        if (tabRecepcion) {
          tabRecepcion.addEventListener("click", () => {
            resetTabs();
            tabRecepcion.classList.add("active");
            activeFilter = 'recepcion';
            renderOrders();
          });
        }
        
        if (tabPreparacion) {
          tabPreparacion.addEventListener("click", () => {
            resetTabs();
            tabPreparacion.classList.add("active");
            activeFilter = 'preparacion';
            renderOrders();
          });
        }

        if (tabTransito) {
          tabTransito.addEventListener("click", () => {
            resetTabs();
            tabTransito.classList.add("active");
            activeFilter = 'transito';
            renderOrders();
          });
        }
        
        if (tabNovedades) {
          tabNovedades.addEventListener("click", () => {
            resetTabs();
            tabNovedades.classList.add("active");
            activeFilter = 'novedades';
            renderOrders();
          });
        }

        // Initial setup
        const navAvatar = document.getElementById("nav-despachador-avatar");
        if (navAvatar && user.avatar) {
          navAvatar.src = user.avatar;
        }

        // 6. Manejar entrada de búsqueda de texto
        searchInput.addEventListener("input", renderOrders);

        // Cargar pedidos al arrancar
        fetchAllOrders();

        // 7. Notificaciones en Tiempo Real (Polling)
        let lastOrderCount = 0;
        setInterval(async () => {
          try {
            const response = await fetch("/api/compra/todas", { headers: authHeaders });
            if (response.ok) {
              const latestOrders = await response.json();
              if (latestOrders.length > allOrders.length) {
                // Nuevo pedido detectado!
                allOrders = latestOrders;
                renderOrders();
                
                // Reproducir sonido simple
                const context = new (window.AudioContext || window.webkitAudioContext)();
                const oscillator = context.createOscillator();
                oscillator.type = 'sine';
                oscillator.frequency.setValueAtTime(880, context.currentTime); // Tono alto
                oscillator.connect(context.destination);
                oscillator.start();
                oscillator.stop(context.currentTime + 0.1);
                setTimeout(() => {
                  const osc2 = context.createOscillator();
                  osc2.frequency.setValueAtTime(1100, context.currentTime);
                  osc2.connect(context.destination);
                  osc2.start();
                  osc2.stop(context.currentTime + 0.2);
                }, 150);
              } else {
                // Solo actualizar silenciosamente
                allOrders = latestOrders;
                renderOrders();
              }
            }
          } catch (e) {
            console.error("Error en polling:", e);
          }
        }, 15000); // Actualizar cada 15 segundos
      });
    </script>
    <!-- Incluir main.js para activar interceptor global -->
    <script src="../js/main.js"></script>
  </body>
</html>
