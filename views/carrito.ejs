<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Carrito de Compras - Agro-Campo</title>
    <link rel="icon" href="../img/logo vaca.png" type="image/x-icon" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link rel="stylesheet" href="../css/carrito.css" />
    <link rel="stylesheet" href="../css/style.css" />
  </head>
  <body>
    <%- include('partials/header') %>

    <!-- Banner decorativo del carrito del campo -->
    <div style="width:100%; height: 180px; background: linear-gradient(135deg, rgba(27,67,50,0.65) 0%, rgba(16,185,129,0.45) 100%), url('https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&w=1200&q=80') no-repeat center center/cover; position: relative; display: flex; align-items: flex-end; padding: 0 40px 25px 40px; box-sizing: border-box; color: white;">
      <div>
        <h1 style="margin: 0; font-size: 2.2em; font-weight: 800; text-shadow: 0 2px 4px rgba(0,0,0,0.3); letter-spacing: -0.5px;">Mi Carrito de Compras</h1>
        <p style="margin: 5px 0 0 0; font-size: 1.05em; text-shadow: 0 1px 2px rgba(0,0,0,0.2); opacity: 0.95;">Revisa tus productos seleccionados y apoya al campo local</p>
      </div>
    </div>

    <main class="cart-container">
      <div class="cart-items" id="cart-items-container">
        <!-- Los productos se agregarán dinámicamente aquí -->
      </div>

      <div class="cart-summary">
        <h3>Resumen de Compra</h3>

        <!-- Widget dinámico del rastreador de envío gratis -->
        <div class="free-shipping-tracker">
          <p class="free-shipping-text" id="free-shipping-tracker-text">
            <i class="fa fa-truck"></i> Calculando envío...
          </p>
          <div class="free-shipping-progress-bg">
            <div class="free-shipping-progress-bar" id="free-shipping-progress-bar" style="width: 0%;"></div>
          </div>
        </div>

        <div class="summary-details">
          <div class="summary-row">
            <span>Subtotal:</span>
            <span id="subtotal">$0.00</span>
          </div>
          <div class="summary-row">
            <span>Envío:</span>
            <span id="shipping">$2.00</span>
          </div>
          <div class="summary-row total">
            <span>Total:</span>
            <span id="total">$2.00</span>
          </div>
        </div>
        <a href="#" class="btn-checkout">Proceder al Pago <i class="fa fa-arrow-right"></i></a>
      </div>

      <!-- Contenedor Modal para mostrar la Factura como una Alerta Pop-up -->
      <div id="invoice-modal" class="modal" style="display: none; position: fixed; z-index: 3000; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.5); align-items: center; justify-content: center;">
        <div class="modal-content" style="background-color: #fff; margin: auto; padding: 25px; border-radius: 12px; max-width: 600px; width: 90%; box-shadow: 0 4px 20px rgba(0,0,0,0.2); position: relative; border-top: 8px solid #10b981; box-sizing: border-box; text-align: left;">
          <span class="close-modal" id="close-invoice-modal" style="position: absolute; right: 20px; top: 15px; font-size: 28px; font-weight: bold; color: #aaa; cursor: pointer; transition: color 0.2s; z-index: 10;">&times;</span>
          
          <!-- Contenedor del Recibo para imprimir/ver -->
          <div id="receipt-invoice-print-area" style="padding: 10px; background-color: white;">
            <div style="text-align: center; border-bottom: 2px dashed #ddd; padding-bottom: 15px; margin-bottom: 15px;">
              <h2 style="margin: 0; color: #1b4332; font-size: 1.6em;">AGRO-CAMPO S.A.S</h2>
              <p style="margin: 5px 0; font-size: 0.85em; color: #777;">Nit: 1050277880 | Tel: 3008723989</p>
              <p style="margin: 8px 0 5px 0; font-size: 0.95em; font-weight: bold; color: #333; letter-spacing: 1px;">RECIBO ELECTRÓNICO DE COMPRA</p>
            </div>
            
            <div style="display: flex; justify-content: space-between; font-size: 0.9em; margin-bottom: 15px;">
              <div>
                <strong>Cliente:</strong> <span id="invoice-client">Consumidor Final</span><br>
                <strong>Dirección de Envío:</strong> <span id="invoice-shipping-address" style="color: #475569;">---</span><br>
                <strong>Fecha:</strong> <span id="invoice-date">---</span><br>
                <strong>Método de Pago:</strong> <span id="invoice-payment-method" style="font-weight: bold; color: #2e7d32;">---</span>
              </div>
              <div style="text-align: right;">
                <strong>Pedido Nº:</strong> <span id="invoice-order-number" style="font-weight: bold; color: #1b4332;">#</span>
              </div>
            </div>
            
            <table style="width: 100%; border-collapse: collapse; font-size: 0.9em; margin-bottom: 15px;">
              <thead>
                <tr style="border-bottom: 2px solid #10b981; text-align: left; font-weight: bold; background-color: #f5f8fa;">
                  <th style="padding: 8px; border: 1px solid #ddd;">Producto</th>
                  <th style="padding: 8px; border: 1px solid #ddd; text-align: center;">Cant.</th>
                  <th style="padding: 8px; border: 1px solid #ddd; text-align: right;">P. Unit</th>
                  <th style="padding: 8px; border: 1px solid #ddd; text-align: right;">Total</th>
                </tr>
              </thead>
              <tbody id="invoice-products">
                <!-- Líneas cargadas dinámicamente -->
              </tbody>
            </table>
            
            <div style="border-top: 1px solid #ddd; padding-top: 10px; margin-top: 15px; font-size: 0.95em;">
              <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                <span>Subtotal:</span>
                <span id="invoice-subtotal">$0.00</span>
              </div>
              <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                <span>Envío:</span>
                <span id="invoice-shipping">$0.00</span>
              </div>
              <div style="display: flex; justify-content: space-between; font-weight: bold; font-size: 1.15em; border-top: 2px solid #10b981; padding-top: 8px; margin-top: 8px; color: #1b4332;">
                <span>Total Pagado:</span>
                <span id="invoice-total">$0.00</span>
              </div>
            </div>
            
            <div style="text-align: center; margin-top: 25px; border-top: 1px dashed #ddd; padding-top: 15px; font-size: 0.85em; color: #777;">
              <p style="margin: 3px 0;">¡Gracias por apoyar a nuestros agricultores locales!</p>
              <p style="margin: 3px 0; font-weight: bold; color: #10b981;">Agro-Campo - Del campo a tu mesa</p>
            </div>
          </div>

          <!-- Enviar Factura Electrónica por Correo -->
          <div style="background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 15px; margin-top: 20px; box-sizing: border-box;">
            <label for="send-email-invoice-input" style="display: block; font-weight: bold; color: #1b4332; font-size: 0.9em; margin-bottom: 8px;">
              <i class="fa fa-envelope"></i> Enviar Factura al Correo Electrónico:
            </label>
            <div style="display: flex; gap: 10px;">
              <input type="email" id="send-email-invoice-input" placeholder="correo@ejemplo.com" style="flex: 1; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 0.9em; box-sizing: border-box;" />
              <button type="button" id="btn-send-email-invoice" style="background-color: #2e7d32; color: white; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: bold; font-size: 0.9em; display: flex; align-items: center; gap: 6px; transition: background 0.2s;">
                <i class="fa fa-paper-plane"></i> Enviar
              </button>
            </div>
          </div>
          
          <div style="display: flex; justify-content: space-between; margin-top: 20px; border-top: 1px solid #eee; padding-top: 15px;">
            <button type="button" id="print-invoice" style="background-color: #1b4332; color: white; border: none; padding: 10px 18px; border-radius: 6px; cursor: pointer; font-weight: bold; display: flex; align-items: center; gap: 8px;">
              <i class="fa fa-file-pdf"></i> Descargar PDF
            </button>
            <button type="button" id="close-invoice-modal-btn" style="background-color: #ddd; color: #333; border: none; padding: 10px 18px; border-radius: 6px; cursor: pointer; font-weight: bold;">
              Cerrar Recibo
            </button>
          </div>
        </div>
      </div>
    </main>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="../js/carrito.js"></script>
    <script src="../js/main.js"></script>
  </body>
  <!-- Loader global -->
  <div id="global-loader" style="display:none;">
    <div class="loader-backdrop"></div>
    <div class="loader-spinner">
      <i id="loader-icon" class="fa fa-spinner fa-spin fa-3x" style="color: #4f46e5; transition: all 0.3s ease;"></i>
      <p id="loader-text" style="font-weight: 600; margin-top: 15px; font-size: 1.1em; transition: all 0.3s ease;">Cargando...</p>
    </div>
  </div>
</html>
