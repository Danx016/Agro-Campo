<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recuperar Contraseña - Agro-Campo</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.6) 0%, rgba(20, 83, 45, 0.8) 100%), url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1800&q=80') no-repeat center center fixed;
            background-size: cover;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
            font-family: 'Outfit', sans-serif;
        }

        .recover-container {
            background-color: rgba(255, 255, 255, 0.96);
            border-radius: 20px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            width: 100%;
            max-width: 420px;
            padding: 2.2rem 2rem;
            border-top: 6px solid #10b981;
            backdrop-filter: blur(10px);
            animation: fadeInUp 0.4s ease;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Header */
        .recover-header {
            text-align: center;
            margin-bottom: 1.8rem;
        }

        .recover-header .icon-top {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, #1b4332 0%, #10b981 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            box-shadow: 0 4px 15px rgba(16, 185, 129, 0.35);
        }

        .recover-header .icon-top i {
            color: white;
            font-size: 1.7rem;
        }

        .recover-header h1 {
            color: #1b4332;
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            margin-bottom: 0.4rem;
        }

        .recover-header p {
            color: #64748b;
            font-size: 0.92rem;
            font-weight: 500;
            line-height: 1.5;
        }

        /* Step indicator */
        .steps-indicator {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0;
            margin-bottom: 1.8rem;
        }

        .step-dot {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: #e2e8f0;
            color: #94a3b8;
            font-size: 0.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }

        .step-dot.active {
            background: linear-gradient(135deg, #1b4332 0%, #10b981 100%);
            color: white;
            box-shadow: 0 2px 8px rgba(16, 185, 129, 0.4);
        }

        .step-dot.done {
            background: #10b981;
            color: white;
        }

        .step-line {
            width: 50px;
            height: 3px;
            background: #e2e8f0;
            transition: background 0.3s;
        }

        .step-line.active {
            background: linear-gradient(to right, #1b4332, #10b981);
        }

        /* Form groups */
        .form-group {
            margin-bottom: 1.3rem;
            position: relative;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.6rem;
            color: #334155;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .input-with-icon {
            position: relative;
        }

        .input-with-icon i {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 0.95rem;
            pointer-events: none;
        }

        .input-with-icon input {
            width: 100%;
            padding: 11px 15px 11px 38px;
            border: 1.5px solid #cbd5e1;
            border-radius: 10px;
            font-size: 0.97rem;
            transition: all 0.25s;
            color: #1e293b;
            background: #ffffff;
            outline: none;
        }

        .input-with-icon input:focus {
            border-color: #10b981;
            box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.15);
            background: #ffffff;
        }

        /* Buttons */
        .recover-btn {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, #1b4332 0%, #10b981 100%);
            border: none;
            border-radius: 10px;
            color: white;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.25s ease;
            margin-top: 0.4rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: 0 4px 15px rgba(27, 67, 50, 0.2);
        }

        .recover-btn:hover {
            opacity: 1;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(16, 185, 129, 0.3);
            filter: brightness(1.05);
        }

        .recover-btn:active {
            transform: translateY(0);
        }

        /* Links */
        .back-link {
            text-align: center;
            margin-top: 1.4rem;
            font-size: 0.88rem;
        }

        .back-link a {
            color: #10b981;
            text-decoration: none;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: color 0.2s ease;
        }

        .back-link a:hover {
            color: #047857;
            text-decoration: underline;
        }

        .divider {
            border-top: 1px dashed #cbd5e1;
            margin: 1.2rem 0 1rem;
        }

        /* Steps info box */
        .steps-info {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            border-radius: 8px;
            padding: 1rem 1.1rem;
            margin-top: 1.5rem;
        }

        .steps-info h3 {
            font-size: 0.88rem;
            color: #166534;
            margin-bottom: 0.6rem;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .steps-info ol {
            padding-left: 1.2rem;
            margin: 0;
        }

        .steps-info ol li {
            font-size: 0.82rem;
            color: #374151;
            margin-bottom: 4px;
            line-height: 1.4;
        }

        /* Success modal */
        .modal {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 10000;
            background: rgba(0,0,0,0.55);
            backdrop-filter: blur(4px);
            align-items: center;
            justify-content: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: white;
            border-radius: 20px;
            padding: 2.5rem 2rem;
            max-width: 380px;
            width: 90%;
            text-align: center;
            box-shadow: 0 20px 50px rgba(0,0,0,0.2);
            border-top: 6px solid #10b981;
            animation: fadeInUp 0.35s ease;
        }

        .modal-icon {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.2rem;
            font-size: 2rem;
            background: linear-gradient(135deg, #1b4332 0%, #10b981 100%);
            color: white;
            box-shadow: 0 6px 20px rgba(16, 185, 129, 0.35);
        }

        .modal-content h2 {
            color: #166534;
            margin-bottom: 0.7rem;
            font-size: 1.4rem;
        }

        .modal-content p {
            color: #555;
            font-size: 0.9rem;
            line-height: 1.5;
            margin-bottom: 1.5rem;
        }

        .modal-button {
            padding: 11px 24px;
            background: linear-gradient(135deg, #1b4332 0%, #10b981 100%);
            border: none;
            border-radius: 10px;
            color: white;
            font-size: 0.97rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.25s ease;
            box-shadow: 0 4px 15px rgba(27, 67, 50, 0.25);
        }

        .modal-button:hover {
            opacity: 1;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(16, 185, 129, 0.35);
            filter: brightness(1.05);
        }

        /* Loader global */
        #global-loader {
            position: fixed;
            z-index: 9999;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        #global-loader .loader-backdrop {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.4);
            backdrop-filter: blur(4px);
        }

        #global-loader .loader-spinner {
            position: relative;
            z-index: 2;
            background: #ffffff;
            padding: 2.2rem 2.8rem;
            border-radius: 16px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 14px;
            min-width: 260px;
            border-top: 5px solid #10b981;
        }

        #global-loader .loader-spinner i { margin: 0; color: #10b981; }
        #global-loader .loader-spinner p { margin: 0; color: #333; font-weight: 600; font-size: 1.05em; line-height: 1.4; }

    </style>
</head>
<body>

    <div class="recover-container">
        <!-- Header -->
        <div class="recover-header">
            <div class="icon-top">
                <i class="fas fa-lock-open"></i>
            </div>
            <h1>¿Olvidaste tu contraseña?</h1>
            <p>Ingresa tu correo y te enviaremos un código de recuperación</p>
        </div>

        <!-- Indicador de pasos -->
        <div class="steps-indicator">
            <div class="step-dot active" id="dot-1">1</div>
            <div class="step-line" id="line-1"></div>
            <div class="step-dot" id="dot-2">2</div>
            <div class="step-line" id="line-2"></div>
            <div class="step-dot" id="dot-3">✓</div>
        </div>

        <form id="passwordForm" class="password-form">

            <!-- PASO 1: Correo -->
            <div id="step-1">
                <div class="form-group">
                    <label for="email"><i class="fas fa-envelope" style="color:#3ba75a; margin-right:5px;"></i> Correo electrónico</label>
                    <div class="input-with-icon">
                        <i class="fas fa-envelope"></i>
                        <input type="email" id="email" placeholder="Ingresa tu correo registrado" required>
                    </div>
                </div>
                <button type="button" id="btn-send-code" class="recover-btn">
                    <i class="fas fa-paper-plane"></i> Enviar código de recuperación
                </button>
            </div>

            <!-- PASO 2: Código + Nueva contraseña -->
            <div id="step-2" style="display: none;">
                <div class="form-group">
                    <label for="recovery-code"><i class="fas fa-key" style="color:#3ba75a; margin-right:5px;"></i> Código de seguridad (6 dígitos)</label>
                    <div class="input-with-icon">
                        <i class="fas fa-key"></i>
                        <input type="text" id="recovery-code" maxlength="6" placeholder="Código enviado a tu correo" autocomplete="off">
                    </div>
                </div>
                <div class="form-group">
                    <label for="new-password"><i class="fas fa-lock" style="color:#3ba75a; margin-right:5px;"></i> Nueva contraseña</label>
                    <div class="input-with-icon">
                        <i class="fas fa-lock"></i>
                        <input type="password" id="new-password" placeholder="Mínimo 8 caracteres">
                    </div>
                </div>
                <div class="form-group">
                    <label for="confirm-password"><i class="fas fa-lock" style="color:#3ba75a; margin-right:5px;"></i> Confirmar contraseña</label>
                    <div class="input-with-icon">
                        <i class="fas fa-lock"></i>
                        <input type="password" id="confirm-password" placeholder="Repite tu nueva contraseña">
                    </div>
                </div>
                <button type="submit" id="btn-reset-password" class="recover-btn">
                    <i class="fas fa-shield-halved"></i> Restablecer contraseña
                </button>
                <div style="text-align: center; margin-top: 1rem;">
                    <a href="#" id="btn-back-to-step-1" style="font-size: 0.88rem; color: #3aac67; text-decoration: none;">
                        <i class="fas fa-arrow-left"></i> Cambiar correo / Reenviar
                    </a>
                </div>
            </div>

            <div class="divider"></div>

            <div class="back-link">
                <a href="/login"><i class="fas fa-arrow-left"></i> Volver al inicio de sesión</a>
            </div>
        </form>

        <!-- Info de pasos -->
        <div class="steps-info">
            <h3><i class="fas fa-circle-info"></i> Proceso de recuperación:</h3>
            <ol>
                <li>Ingresa tu dirección de correo electrónico registrado</li>
                <li>Recibirás un código de 6 dígitos en tu bandeja de entrada</li>
                <li>Ingresa el código y establece tu nueva contraseña</li>
                <li>¡Listo! Inicia sesión con tus nuevas credenciales</li>
            </ol>
        </div>
    </div>

    <!-- Modal de éxito -->
    <div id="successModal" class="modal">
        <div class="modal-content">
            <div class="modal-icon">
                <i class="fas fa-check"></i>
            </div>
            <h2>¡Contraseña restablecida!</h2>
            <p>Tu contraseña ha sido actualizada exitosamente. Ya puedes iniciar sesión con tus nuevas credenciales.</p>
            <button id="closeModal" class="modal-button">
                <i class="fas fa-arrow-right-to-bracket"></i> Ir al inicio de sesión
            </button>
        </div>
    </div>

    <!-- Loader global -->
    <div id="global-loader" style="display:none;">
        <div class="loader-backdrop"></div>
        <div class="loader-spinner">
            <i id="loader-icon" class="fa fa-spinner fa-spin fa-3x"></i>
            <p id="loader-text">Cargando...</p>
        </div>
    </div>

    <script src="../js/olvidaste_contraseña.js"></script>
    <script src="../js/main.js"></script>

    <!-- Script para indicador de pasos visual -->
    <script>
        // Conectar el indicador visual con el flujo de pasos
        const dot1 = document.getElementById('dot-1');
        const dot2 = document.getElementById('dot-2');
        const dot3 = document.getElementById('dot-3');
        const line1 = document.getElementById('line-1');
        const line2 = document.getElementById('line-2');
        const btnBack = document.getElementById('btn-back-to-step-1');

        // Cuando se envía el código (observar cuándo aparece step-2)
        const observer = new MutationObserver(() => {
            const step2 = document.getElementById('step-2');
            if (step2 && step2.style.display !== 'none') {
                dot1.classList.remove('active');
                dot1.classList.add('done');
                dot1.innerHTML = '<i class="fas fa-check" style="font-size:0.75rem;"></i>';
                line1.classList.add('active');
                dot2.classList.add('active');
            } else {
                dot1.classList.add('active');
                dot1.classList.remove('done');
                dot1.textContent = '1';
                line1.classList.remove('active');
                dot2.classList.remove('active');
            }
        });

        const step2El = document.getElementById('step-2');
        if (step2El) observer.observe(step2El, { attributes: true, attributeFilter: ['style'] });

        // Al hacer clic en "Volver" => resetear indicador
        if (btnBack) {
            btnBack.addEventListener('click', () => {
                dot1.classList.add('active');
                dot1.classList.remove('done');
                dot1.textContent = '1';
                line1.classList.remove('active');
                dot2.classList.remove('active');
            });
        }

        // Modal de éxito cerrar
        const closeModal = document.getElementById('closeModal');
        if (closeModal) {
            closeModal.addEventListener('click', () => {
                window.location.href = '/login';
            });
        }
    </script>
</body>
</html>
