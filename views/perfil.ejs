<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mi Perfil - Agro-Campo</title>
    <link rel="icon" href="../img/logo vaca.png" type="image/x-icon" />
    <link rel="stylesheet" href="../css/style.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link rel="stylesheet" href="../css/perfil.css" />
  </head>
  <body>
    <%- include('partials/header') %>

    <!-- Banner decorativo del campo premium -->
    <div style="width:100%; height: 180px; background: linear-gradient(135deg, rgba(27,67,50,0.65) 0%, rgba(16,185,129,0.45) 100%), url('https://images.unsplash.com/photo-1625246333195-78d9c38ad449?auto=format&fit=crop&w=1200&q=80') no-repeat center center/cover; position: relative; display: flex; align-items: flex-end; padding: 0 40px 25px 40px; box-sizing: border-box; color: white;">
      <div>
        <h1 style="margin: 0; font-size: 2.2em; font-weight: 800; text-shadow: 0 2px 4px rgba(0,0,0,0.3); letter-spacing: -0.5px;">Mi Agro-Perfil</h1>
        <p style="margin: 5px 0 0 0; font-size: 1.05em; text-shadow: 0 1px 2px rgba(0,0,0,0.2); opacity: 0.95;">Gestiona tus datos de campo, historial y direcciones</p>
      </div>
    </div>

    <div class="profile-dashboard-layout">
      <!-- Columna Izquierda: Sidebar Card -->
      <aside class="profile-sidebar-card">
        <div class="sidebar-user-info" style="text-align: center; padding-bottom: 20px; border-bottom: 1px solid #f1f5f9; margin-bottom: 20px;">
          <div class="avatar-preview-wrapper" style="position: relative; display: inline-block; margin-bottom: 12px;">
            <img id="profile-avatar-preview" src="../img/logo vaca.png" alt="Avatar actual" class="profile-avatar-preview" style="width: 110px; height: 110px; border-radius: 50%; object-fit: cover; border: 4px solid #10b981; box-shadow: 0 4px 12px rgba(16,185,129,0.15);">
          </div>
          <h2 id="sidebar-display-name" style="margin: 5px 0 2px 0; color: #1b4332; font-size: 1.25em; font-weight: 700;">Cargando...</h2>
          <p id="sidebar-display-email" style="margin: 0; color: #64748b; font-size: 0.9em;">Cargando...</p>
          
          <!-- Balance de Agro-Créditos -->
          <div style="margin-top: 15px; padding: 12px; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 12px; display: inline-block; min-width: 150px;">
            <span style="display: block; font-size: 0.8em; font-weight: 700; color: #166534; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 3px;">
              <i class="fa fa-coins"></i> Agro-Créditos
            </span>
            <span id="sidebar-display-credits" style="font-size: 1.4em; font-weight: 800; color: #10b981;">$0</span>
          </div>
        </div>

        <!-- Selector de Pestañas Premium (Menú Lateral) -->
        <div class="profile-tabs-wrapper" style="display: flex; flex-direction: column; gap: 8px; border-bottom: none; margin-bottom: 0;">
          <button type="button" class="profile-tab-btn active" id="tab-account" style="text-align: left; width: 100%; justify-content: flex-start; padding: 12px 16px; border-radius: 8px; border: none; border-left: 4px solid transparent;">
            <i class="fa fa-user-circle"></i> Mi Cuenta
          </button>
          <button type="button" class="profile-tab-btn" id="tab-purchases" style="text-align: left; width: 100%; justify-content: flex-start; padding: 12px 16px; border-radius: 8px; border: none; border-left: 4px solid transparent;">
            <i class="fa fa-shopping-bag"></i> Mis Compras
          </button>
          <button type="button" class="profile-tab-btn" id="tab-addresses" style="text-align: left; width: 100%; justify-content: flex-start; padding: 12px 16px; border-radius: 8px; border: none; border-left: 4px solid transparent;">
            <i class="fa fa-map-marker-alt"></i> Mis Direcciones
          </button>
        </div>
      </aside>

      <!-- Columna Derecha: Content Card -->
      <main class="profile-content-card" style="flex: 1; background: #ffffff; border-radius: 16px; box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05); padding: 35px 30px; border: 1px solid #e2e8f0; box-sizing: border-box; min-height: 480px;">
        
        <!-- Sección 1: Datos de la Cuenta -->
        <div id="section-account" class="profile-tab-section active" style="width: 100%;">
          <h2 style="color: #1b4332; margin-top: 0; margin-bottom: 20px; font-size: 1.5em; font-weight: 700; display: flex; align-items: center; gap: 8px;"><i class="fa fa-cog"></i> Ajustes de Mi Cuenta</h2>
          
          <form id="profile-form">
            <!-- Selección de Foto de Perfil Premium -->
            <div class="avatar-selection-container" style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px; box-sizing: border-box; margin-bottom: 25px;">
              <span class="avatar-options-label" style="display: block; font-weight: 700; color: #1b4332; font-size: 0.95em; margin-bottom: 12px;"><i class="fa fa-images"></i> Personaliza tu avatar de granja:</span>
              
              <div class="avatar-presets" style="display: flex; gap: 15px; margin-bottom: 15px; justify-content: flex-start;">
                <img class="avatar-preset" src="../img/logo vaca.png" alt="Vaca" title="Vaca (Por defecto)">
                <img class="avatar-preset" src="https://images.unsplash.com/photo-1570042225831-d98fa7577f1e?auto=format&fit=crop&w=150&h=150&q=80" alt="Vaca Real" title="Vaca Real">
                <img class="avatar-preset" src="https://images.unsplash.com/photo-1516467508483-a7212febe31a?auto=format&fit=crop&w=150&h=150&q=80" alt="Cerdo" title="Cerdo">
                <img class="avatar-preset" src="https://images.unsplash.com/photo-1484557985045-edf25e08da73?auto=format&fit=crop&w=150&h=150&q=80" alt="Oveja" title="Oveja">
                <img class="avatar-preset" src="https://images.unsplash.com/photo-1548550023-2bdb3c5beed7?auto=format&fit=crop&w=150&h=150&q=80" alt="Pollito" title="Pollito">
              </div>
              
              <div class="avatar-url-wrapper" style="display: none;">
                <label style="font-size: 0.85em; font-weight: 600; color: #334155; margin-bottom: 5px; display: block;">Pegar URL externa de imagen:</label>
                <input type="text" id="profile-avatar-url" placeholder="O pega la URL de tu propia foto...">
              </div>
              
              <div class="avatar-upload-btn-wrapper">
                <button type="button" class="btn-upload">
                  <i class="fa fa-upload"></i> Subir foto desde mi PC
                </button>
                <input type="file" id="profile-avatar-file" accept="image/*">
              </div>
            </div>

            <!-- Grid de Formulario de Dos Columnas -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 10px;">
              <div style="grid-column: span 1;">
                <label style="display: flex; flex-direction: column; font-weight: 600; color: #334155; font-size: 0.95em; gap: 8px;">
                  Nombre Completo:
                  <input type="text" id="profile-name" required />
                </label>
              </div>
              <div style="grid-column: span 1;">
                <label style="display: flex; flex-direction: column; font-weight: 600; color: #334155; font-size: 0.95em; gap: 8px;">
                  Correo Electrónico:
                  <input type="email" id="profile-email" required />
                </label>
              </div>
              <div style="grid-column: span 1;">
                <label style="display: flex; flex-direction: column; font-weight: 600; color: #334155; font-size: 0.95em; gap: 8px;">
                  Nombre de Usuario:
                  <input type="text" id="profile-username" required />
                </label>
              </div>
              <div style="grid-column: span 1;">
                <label style="display: flex; flex-direction: column; font-weight: 600; color: #334155; font-size: 0.95em; gap: 8px;">
                  Nueva Contraseña:
                  <input
                    type="password"
                    id="profile-password"
                    placeholder="(Dejar en blanco para no cambiar)"
                  />
                </label>
              </div>
            </div>
            
            <!-- Contenedor dinámico de confirmación de contraseña por correo -->
            <div id="password-verification-container" style="display: none; margin-top: 1em; border: 1px dashed #10b981; padding: 15px; border-radius: 8px; background-color: #f0fdf4;">
              <p style="font-size: 0.9em; margin: 0 0 10px 0; color: #1b4332; font-weight: bold;">
                <i class="fa fa-shield-alt"></i> Seguridad: Confirma tu cambio de contraseña
              </p>
              <p style="font-size: 0.8em; margin: 0 0 12px 0; color: #555555; line-height: 1.4;">
                Para cambiar tu contraseña, debes ingresar un código de verificación de 6 dígitos que enviaremos a tu correo electrónico registrado.
              </p>
              <button type="button" id="btn-request-profile-code" style="font-size: 0.85em; padding: 8px 14px; background-color: #10b981; color: white; border: none; border-radius: 6px; cursor: pointer; display: inline-block;">
                <i class="fa fa-paper-plane"></i> Enviar código al correo
              </button>
              <label style="display: block; font-size: 0.85em; margin-top: 12px; font-weight: bold; color: #333;">
                Código de confirmación (6 dígitos):
                <input type="text" id="profile-reset-code" maxlength="6" placeholder="Código de 6 dígitos" style="margin-top: 6px; padding: 10px; width: 100%; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box; text-align: center; font-size: 1.1em; letter-spacing: 2px;" />
              </label>
            </div>
            
            <button type="submit" class="btn-primary" style="width: 100%; margin-top: 20px;">Guardar Cambios</button>
          </form>

          <button id="delete-account" class="btn-danger" style="margin-top: 15px;">Eliminar Cuenta</button>
          
          <!-- Contenedor dinámico de confirmación para eliminar cuenta -->
          <div id="delete-verification-container" style="display: none; margin-top: 1em; border: 1.5px dashed #ef4444; padding: 18px; border-radius: 8px; background-color: #fffafb; box-sizing: border-box;">
            <p style="font-size: 0.95em; margin: 0 0 10px 0; color: #ef4444; font-weight: bold; display: flex; align-items: center; gap: 6px;">
              <i class="fa fa-exclamation-triangle"></i> Confirmación de Seguridad: Eliminar Cuenta
            </p>
            <p style="font-size: 0.82em; margin: 0 0 12px 0; color: #555555; line-height: 1.45;">
              Por tu seguridad, para eliminar definitivamente tu Agro-Cuenta debes solicitar un código de verificación de 6 dígitos que enviaremos a tu correo electrónico registrado.
            </p>
            <div style="display: flex; flex-direction: column; gap: 12px;">
              <button type="button" id="btn-request-delete-code" style="font-size: 0.85em; padding: 10px 14px; background-color: #ef4444; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; display: inline-flex; align-items: center; justify-content: center; gap: 6px; transition: background 0.2s;">
                <i class="fa fa-paper-plane"></i> Enviar Código al Correo
              </button>
              <label style="display: block; font-size: 0.85em; margin-top: 5px; font-weight: bold; color: #333;">
                Introduce el Código de 6 dígitos recibido:
                <input type="text" id="delete-verification-code" maxlength="6" placeholder="Código de 6 dígitos" style="margin-top: 6px; padding: 10px; width: 100%; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box; text-align: center; font-size: 1.2em; font-weight: bold; letter-spacing: 4px;" />
              </label>
              <button type="button" id="btn-confirm-delete-account" style="font-size: 0.9em; padding: 12px 18px; background-color: #b91c1c; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; display: inline-flex; align-items: center; justify-content: center; gap: 8px; margin-top: 5px; transition: background 0.2s;">
                <i class="fa fa-trash-alt"></i> Confirmar y Eliminar Mi Cuenta Permanentemente
              </button>
            </div>
          </div>

          <div id="profile-message"></div>
        </div>

        <!-- Sección 2: Historial de Compras -->
        <div id="section-purchases" class="profile-tab-section" style="display: none; width: 100%;">
          <div class="purchase-history-container" style="margin-top: 0; padding-top: 0; margin-bottom: 1em;">
            <h2 style="color: #1b4332; margin-top: 0; margin-bottom: 20px; font-size: 1.5em; font-weight: 700;"><i class="fa fa-history"></i> Mi Historial de Compras</h2>
            <div id="history-loading" style="display: none; text-align: center; padding: 20px;">
              <i class="fa fa-spinner fa-spin fa-2x" style="color: #10b981;"></i>
              <p style="margin-top: 10px; color: #64748b;">Cargando historial de compras...</p>
            </div>
            <div id="history-empty" style="display: none; text-align: center; padding: 40px 20px; color: #64748b; background-color: #f8fafc; border-radius: 12px; border: 1px dashed #cbd5e1;">
              <i class="fa fa-shopping-bag fa-3x" style="margin-bottom: 15px; color: #cbd5e1;"></i>
              <p style="font-weight: 700; margin: 0; font-size: 1.1em; color: #1e293b;">Aún no has realizado ninguna compra.</p>
              <p style="margin: 5px 0 20px 0; font-size: 0.9em;">¡Apoya a nuestros productores y adquiere productos frescos!</p>
              <a href="/" class="btn-primary" style="display: inline-block; text-decoration: none; padding: 10px 20px; font-size: 0.95em;">Ir a comprar productos</a>
            </div>
            <div class="table-responsive" style="overflow-x: auto; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); border: 1px solid #e2e8f0;">
              <table id="history-table" class="history-table" style="width: 100%; border-collapse: collapse; display: none; background-color: white;">
                <thead>
                  <tr style="background-color: #1b4332; color: white; text-align: left;">
                    <th style="padding: 14px 16px;">Nº Pedido</th>
                    <th style="padding: 14px 16px;">Fecha</th>
                    <th style="padding: 14px 16px;">Total Pagado</th>
                    <th style="padding: 14px 16px; text-align: center;">Estado de Entrega</th>
                    <th style="padding: 14px 16px; text-align: center;">Acciones</th>
                  </tr>
                </thead>
                <tbody id="history-list">
                  <!-- Cargado dinámicamente -->
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Sección 3: Direcciones -->
        <div id="section-addresses" class="profile-tab-section" style="display: none; width: 100%;">
          <div class="purchase-history-container" style="margin-top: 0; padding-top: 0; margin-bottom: 1em;">
            <h2 style="color: #1b4332; margin-top: 0; margin-bottom: 20px; font-size: 1.5em; font-weight: 700;"><i class="fa fa-map-marker-alt"></i> Mis Direcciones de Envío</h2>
            
            <div id="addresses-list-container" style="display: flex; flex-direction: column; gap: 15px;">
              <p style="color: #64748b;"><i class="fa fa-spinner fa-spin"></i> Cargando direcciones...</p>
            </div>

            <button id="btn-show-add-address" class="btn-primary" style="margin-top: 25px; width: 100%;"><i class="fa fa-plus"></i> Añadir Nueva Dirección</button>

            <!-- Formulario Nueva Dirección -->
            <div id="profile-new-address-form" style="display: none; margin-top: 25px; background: #f8fafc; padding: 25px; border-radius: 12px; border: 1px solid #e2e8f0; box-sizing: border-box;">
              <h3 id="address-form-heading" style="margin-top: 0; margin-bottom: 20px; color:#1b4332; font-weight: 700; font-size: 1.2em;"><i class="fa fa-map-marked-alt"></i> Registrar Dirección de Envío</h3>
              <form id="form-profile-add-address">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                  <div style="grid-column: span 2;">
                    <label style="font-size: 0.85em; font-weight: 600; color: #334155; display: block; margin-bottom: 5px;">Título de Identificación (Ej: Casa, Oficina)</label>
                    <input type="text" id="prof-ship-title" style="width: 100%; padding: 12px; border: 1px solid #cbd5e1; border-radius: 8px; box-sizing: border-box; background: white;" placeholder="Ej: Mi Casa" required />
                  </div>
                  <div style="grid-column: span 2;">
                    <label style="font-size: 0.85em; font-weight: 600; color: #334155; display: block; margin-bottom: 5px;">Dirección Principal *</label>
                    <input type="text" id="prof-ship-address" style="width: 100%; padding: 12px; border: 1px solid #cbd5e1; border-radius: 8px; box-sizing: border-box; background: white;" placeholder="Calle, Carrera, Avenida, Número..." required />
                  </div>
                  <div>
                    <label style="font-size: 0.85em; font-weight: 600; color: #334155; display: block; margin-bottom: 5px;">Departamento *</label>
                    <select id="prof-ship-state" style="width: 100%; padding: 12px; border: 1px solid #cbd5e1; border-radius: 8px; box-sizing: border-box; background: white;" required>
                      <option value="">Seleccione...</option>
                      <option value="Antioquia">Antioquia</option>
                      <option value="Cundinamarca">Cundinamarca</option>
                      <option value="Valle del Cauca">Valle del Cauca</option>
                      <option value="Atlántico">Atlántico</option>
                      <option value="Santander">Santander</option>
                    </select>
                  </div>
                  <div>
                    <label style="font-size: 0.85em; font-weight: 600; color: #334155; display: block; margin-bottom: 5px;">Ciudad *</label>
                    <input type="text" id="prof-ship-city" style="width: 100%; padding: 12px; border: 1px solid #cbd5e1; border-radius: 8px; box-sizing: border-box; background: white;" placeholder="Ciudad / Municipio" required />
                  </div>
                  <div>
                    <label style="font-size: 0.85em; font-weight: 600; color: #334155; display: block; margin-bottom: 5px;">Celular / Teléfono *</label>
                    <input type="tel" id="prof-ship-phone" style="width: 100%; padding: 12px; border: 1px solid #cbd5e1; border-radius: 8px; box-sizing: border-box; background: white;" placeholder="Ej: 3001234567" required />
                  </div>
                  <div>
                    <label style="font-size: 0.85em; font-weight: 600; color: #334155; display: block; margin-bottom: 5px;">Código Postal (Opcional)</label>
                    <input type="text" id="prof-ship-zip" style="width: 100%; padding: 12px; border: 1px solid #cbd5e1; border-radius: 8px; box-sizing: border-box; background: white;" placeholder="Ej: 050001" />
                  </div>
                  <div style="grid-column: span 2;">
                    <label style="font-size: 0.85em; font-weight: 600; color: #334155; display: block; margin-bottom: 5px;">Instrucciones / Barrio / Indicaciones Especiales</label>
                    <textarea id="prof-ship-notes" style="width: 100%; padding: 12px; border: 1px solid #cbd5e1; border-radius: 8px; resize: vertical; min-height: 60px; box-sizing: border-box; background: white; font-family: inherit;" placeholder="Ej: Apto 302, Barrio Laureles, frente al parque..."></textarea>
                  </div>
                </div>
                <div style="display: flex; gap: 12px; margin-top: 20px;">
                  <button type="button" id="btn-cancel-prof-new" style="padding: 12px 20px; border-radius: 8px; border: 1px solid #cbd5e1; background: white; cursor: pointer; font-weight: bold; color: #475569; transition: all 0.2s;">Cancelar</button>
                  <button type="submit" style="padding: 12px 25px; border-radius: 8px; border: none; background: #10b981; color: white; cursor: pointer; font-weight: bold; flex: 1; transition: all 0.2s; box-shadow: 0 4px 12px rgba(16,185,129,0.15);">Guardar Dirección</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Modal del Recibo Electrónico Directo -->
    <div id="receipt-modal" class="modal" style="display: none; position: fixed; z-index: 3000; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.5); align-items: center; justify-content: center;">
      <div class="modal-content" style="background-color: #fff; margin: auto; padding: 25px; border-radius: 12px; max-width: 600px; width: 90%; box-shadow: 0 4px 20px rgba(0,0,0,0.2); position: relative; border-top: 8px solid #10b981; box-sizing: border-box;">
        <span class="close-modal" id="close-receipt-modal" style="position: absolute; right: 20px; top: 15px; font-size: 28px; font-weight: bold; color: #aaa; cursor: pointer; transition: color 0.2s;">&times;</span>
        
        <!-- Contenedor del Recibo para imprimir/ver -->
        <div id="receipt-invoice-print-area" style="padding: 10px; background-color: white;">
          <div style="text-align: center; border-bottom: 2px dashed #ddd; padding-bottom: 15px; margin-bottom: 15px;">
            <h2 style="margin: 0; color: #1b4332; font-size: 1.6em;">AGRO-CAMPO S.A.S</h2>
            <p style="margin: 5px 0; font-size: 0.85em; color: #777;">Nit: 1050277880 | Tel: 3008723989</p>
            <p style="margin: 8px 0 5px 0; font-size: 0.95em; font-weight: bold; color: #333; letter-spacing: 1px;">RECIBO ELECTRÓNICO DE COMPRA</p>
          </div>
          
          <div style="display: flex; justify-content: space-between; font-size: 0.9em; margin-bottom: 15px;">
            <div>
              <strong>Cliente:</strong> <span id="receipt-client-name">Cargando...</span><br>
              <strong>Dirección de Envío:</strong> <span id="receipt-shipping-address" style="color: #475569;">Cargando...</span><br>
              <strong>Fecha:</strong> <span id="receipt-date">Cargando...</span><br>
              <strong>Método de Pago:</strong> <span id="receipt-payment-method" style="font-weight: bold; color: #2e7d32;">Cargando...</span>
            </div>
            <div style="text-align: right;">
              <strong>Pedido Nº:</strong> <span id="receipt-order-id" style="font-weight: bold; color: #1b4332;">Cargando...</span>
            </div>
          </div>
          
          <table style="width: 100%; border-collapse: collapse; font-size: 0.9em; margin-bottom: 15px;">
            <thead>
              <tr style="border-bottom: 2px solid #10b981; text-align: left; font-weight: bold; background-color: #f5f8fa;">
                <th style="padding: 8px; border: 1px solid #ddd;">Producto</th>
                <th style="padding: 8px; border: 1px solid #ddd; text-align: center;">Cant.</th>
                <th style="padding: 8px; border: 1px solid #ddd; text-align: right;">P. Unit</th>
                <th style="padding: 8px; border: 1px solid #ddd; text-align: right;">Total</th>
              </tr>
            </thead>
            <tbody id="receipt-items-list">
              <!-- Líneas cargadas dinámicamente -->
            </tbody>
          </table>
          
          <div style="border-top: 1px solid #ddd; padding-top: 10px; margin-top: 15px; font-size: 0.95em;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
              <span>Subtotal:</span>
              <span id="receipt-subtotal">$0.00</span>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
              <span>Envío:</span>
              <span id="receipt-shipping">$0.00</span>
            </div>
            <div style="display: flex; justify-content: space-between; font-weight: bold; font-size: 1.15em; border-top: 2px solid #10b981; padding-top: 8px; margin-top: 8px; color: #1b4332;">
              <span>Total Pagado:</span>
              <span id="receipt-total">$0.00</span>
            </div>
          </div>
          
          <div style="text-align: center; margin-top: 25px; border-top: 1px dashed #ddd; padding-top: 15px; font-size: 0.85em; color: #777;">
            <p style="margin: 3px 0;">¡Gracias por apoyar a nuestros agricultores locales!</p>
            <p style="margin: 3px 0; font-weight: bold; color: #10b981;">Agro-Campo - Del campo a tu mesa</p>
          </div>
        </div>

        <!-- Enviar Factura Electrónica por Correo -->
        <div style="background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 15px; margin-top: 20px; box-sizing: border-box;">
          <label for="send-email-invoice-input" style="display: block; font-weight: bold; color: #1b4332; font-size: 0.9em; margin-bottom: 8px;">
            <i class="fa fa-envelope"></i> Enviar Factura al Correo Electrónico:
          </label>
          <div style="display: flex; gap: 10px;">
            <input type="email" id="send-email-invoice-input" placeholder="correo@ejemplo.com" style="flex: 1; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 0.9em; box-sizing: border-box;" />
            <button type="button" id="btn-send-email-invoice" style="background-color: #2e7d32; color: white; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: bold; font-size: 0.9em; display: flex; align-items: center; gap: 6px; transition: background 0.2s;">
              <i class="fa fa-paper-plane"></i> Enviar
            </button>
          </div>
        </div>
        
        <div style="display: flex; justify-content: space-between; margin-top: 20px; border-top: 1px solid #eee; padding-top: 15px;">
          <button type="button" id="btn-print-modal-receipt" style="background-color: #1b4332; color: white; border: none; padding: 10px 18px; border-radius: 6px; cursor: pointer; font-weight: bold; display: flex; align-items: center; gap: 8px;">
            <i class="fa fa-file-pdf"></i> Descargar PDF
          </button>
          <button type="button" id="btn-close-modal-receipt" style="background-color: #ddd; color: #333; border: none; padding: 10px 18px; border-radius: 6px; cursor: pointer; font-weight: bold;">
            Cerrar Recibo
          </button>
        </div>
      </div>
    </div>

    <!-- Modal de Rastreo y Línea de Tiempo (Timeline) Premium -->
    <div id="tracking-modal" class="modal" style="display: none; position: fixed; z-index: 3010; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.6); align-items: center; justify-content: center; backdrop-filter: blur(4px);">
      <div class="modal-content" style="background-color: #ffffff; margin: auto; padding: 30px; border-radius: 16px; max-width: 650px; width: 92%; box-shadow: 0 15px 35px rgba(0,0,0,0.3); position: relative; border-top: 8px solid #3b82f6; box-sizing: border-box;">
        <span class="close-modal" id="close-tracking-modal" style="position: absolute; right: 22px; top: 15px; font-size: 28px; font-weight: bold; color: #94a3b8; cursor: pointer; transition: color 0.2s;">&times;</span>
        
        <div style="text-align: center; margin-bottom: 25px; border-bottom: 1px solid #f1f5f9; padding-bottom: 15px;">
          <h2 style="margin: 0; color: #1e293b; font-size: 1.6em; font-weight: 800; display: inline-flex; align-items: center; gap: 10px;">
            <i class="fa fa-map-marker-alt" style="color: #3b82f6;"></i> Seguimiento de Pedido
          </h2>
          <p style="margin: 5px 0 0 0; font-size: 0.95em; color: #64748b;">Código de seguimiento: <strong id="track-order-id" style="color: #1e293b;">#0000</strong></p>
        </div>

        <!-- Estado Destacado de Forma Premium -->
        <div id="track-active-banner" style="background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 12px; padding: 18px; margin-bottom: 25px; display: flex; align-items: center; gap: 16px; box-sizing: border-box;">
          <div id="track-active-icon-wrapper" style="width: 48px; height: 48px; border-radius: 50%; background: #3b82f6; color: white; display: flex; align-items: center; justify-content: center; font-size: 1.4em; box-shadow: 0 4px 10px rgba(59,130,246,0.25);">
            <i class="fa fa-truck-moving"></i>
          </div>
          <div style="flex: 1;">
            <div style="font-size: 0.85em; font-weight: 700; color: #3b82f6; text-transform: uppercase; letter-spacing: 1px;">Estado Actual</div>
            <h3 id="track-active-title" style="margin: 2px 0; color: #1e293b; font-size: 1.25em; font-weight: 800;">Pago Confirmado</h3>
            <p id="track-active-desc" style="margin: 0; color: #475569; font-size: 0.9em; line-height: 1.4;">Hemos verificado correctamente tu transacción bancaria.</p>
          </div>
        </div>

        <!-- Contenedor del Stepper Vertical Premium -->
        <div style="max-height: 380px; overflow-y: auto; padding-right: 8px; margin-bottom: 20px;">
          <div id="tracking-timeline-stepper" style="position: relative; padding-left: 35px; box-sizing: border-box;">
            <!-- La barra vertical del timeline -->
            <div style="position: absolute; left: 14px; top: 10px; bottom: 10px; width: 3px; background-color: #cbd5e1; z-index: 1;"></div>
            
            <!-- Items de la Línea de Tiempo (se inyectan dinámicamente) -->
            <div id="timeline-items-container" style="display: flex; flex-direction: column; gap: 24px; position: relative; z-index: 2;">
              <!-- Se autogenera en JS -->
            </div>
          </div>
        </div>

        <div style="text-align: center; border-top: 1px solid #f1f5f9; padding-top: 20px;">
          <button type="button" id="btn-close-tracking-modal" style="background-color: #f1f5f9; color: #475569; border: none; padding: 11px 25px; border-radius: 8px; cursor: pointer; font-weight: 700; font-size: 0.95em; transition: all 0.2s; border: 1px solid #e2e8f0; width: 100%; box-sizing: border-box;">
            Cerrar Ventana de Rastreo
          </button>
        </div>
      </div>
    </div>
    
    <!-- html2pdf Library para exportación de PDF profesional -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="../js/main.js"></script>
    <script src="../js/profile.js"></script>
  </body>
  <!-- Loader global -->
  <div id="global-loader" style="display:none;">
    <div class="loader-backdrop"></div>
    <div class="loader-spinner">
      <i id="loader-icon" class="fa fa-spinner fa-spin fa-3x" style="color: #4f46e5; transition: all 0.3s ease;"></i>
      <p id="loader-text" style="font-weight: 600; margin-top: 15px; font-size: 1.1em; transition: all 0.3s ease;">Cargando...</p>
    </div>
  </div>
</html>
