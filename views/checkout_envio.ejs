<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dirección de Envío | Agro-Campo</title>
    <link rel="stylesheet" href="../css/style.css" />
    <link rel="stylesheet" href="../css/method_pago.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <style>
      .address-card {
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 15px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: flex-start;
        gap: 15px;
        background: white;
      }
      .address-card:hover {
        border-color: #94a3b8;
      }
      .address-card.selected {
        border-color: #10b981;
        background-color: #f0fdf4;
      }
      .address-radio {
        margin-top: 5px;
      }
      .address-details {
        flex: 1;
      }
      .address-title {
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 5px;
        display: flex;
        justify-content: space-between;
      }
      .address-text {
        font-size: 0.9em;
        color: #475569;
        line-height: 1.5;
      }
      .add-address-btn {
        width: 100%;
        padding: 15px;
        border: 2px dashed #cbd5e1;
        background: transparent;
        color: #64748b;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
      }
      .add-address-btn:hover {
        border-color: #10b981;
        color: #10b981;
        background: #f8fafc;
      }
      .new-address-form {
        display: none;
        background: #f8fafc;
        padding: 20px;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        margin-top: 15px;
      }
      .new-address-form.active {
        display: block;
      }
    </style>
  </head>
  <body>
    <%- include('partials/header') %>
    
    <main class="checkout-main">
      <h2 class="welcome-heading">Paso 1: <span style="color:#10b981;">Dirección de Envío</span></h2>
      
      <div class="checkout-layout">
        <div class="checkout-form-container">
          <div class="payment-methods" style="margin-bottom: 25px;">
            <h3>Selecciona una dirección</h3>
            <p class="subtitle">¿A dónde enviaremos tu pedido?</p>
            
            <div id="saved-addresses-container" style="margin-top: 20px;">
              <p>Cargando direcciones...</p>
            </div>

            <button class="add-address-btn" id="btn-show-new-address">
              <i class="fa fa-plus"></i> Agregar Nueva Dirección
            </button>

            <!-- Formulario Nueva Dirección -->
            <div class="new-address-form" id="new-address-form">
              <h4 style="margin-bottom: 15px; color:#1e293b;">Nueva Dirección</h4>
              <form id="form-add-address">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                  <div style="grid-column: span 2;">
                    <label style="font-size: 0.85em; font-weight: 600;">Título de la Dirección (Ej: Casa, Trabajo)</label>
                    <input type="text" id="ship-title" placeholder="Casa" style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px;" required />
                  </div>
                  <div style="grid-column: span 2;">
                    <label style="font-size: 0.85em; font-weight: 600;">Dirección Principal *</label>
                    <input type="text" id="ship-address" placeholder="Ej: Calle 45 # 12-34" style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px;" required />
                  </div>
                  <div>
                    <label style="font-size: 0.85em; font-weight: 600;">Departamento *</label>
                    <select id="ship-state" style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px;" required>
                      <option value="">Seleccione...</option>
                      <option value="Amazonas">Amazonas</option>
                      <option value="Antioquia">Antioquia</option>
                      <option value="Arauca">Arauca</option>
                      <option value="Atlántico">Atlántico</option>
                      <option value="Bogotá D.C.">Bogotá D.C.</option>
                      <option value="Bolívar">Bolívar</option>
                      <option value="Boyacá">Boyacá</option>
                      <option value="Caldas">Caldas</option>
                      <option value="Caquetá">Caquetá</option>
                      <option value="Casanare">Casanare</option>
                      <option value="Cauca">Cauca</option>
                      <option value="Cesar">Cesar</option>
                      <option value="Chocó">Chocó</option>
                      <option value="Córdoba">Córdoba</option>
                      <option value="Cundinamarca">Cundinamarca</option>
                      <option value="Guainía">Guainía</option>
                      <option value="Guaviare">Guaviare</option>
                      <option value="Huila">Huila</option>
                      <option value="La Guajira">La Guajira</option>
                      <option value="Magdalena">Magdalena</option>
                      <option value="Meta">Meta</option>
                      <option value="Nariño">Nariño</option>
                      <option value="Norte de Santander">Norte de Santander</option>
                      <option value="Putumayo">Putumayo</option>
                      <option value="Quindío">Quindío</option>
                      <option value="Risaralda">Risaralda</option>
                      <option value="San Andrés y Providencia">San Andrés y Providencia</option>
                      <option value="Santander">Santander</option>
                      <option value="Sucre">Sucre</option>
                      <option value="Tolima">Tolima</option>
                      <option value="Valle del Cauca">Valle del Cauca</option>
                      <option value="Vaupés">Vaupés</option>
                      <option value="Vichada">Vichada</option>
                      <option value="Otro">Otro</option>
                    </select>
                  </div>
                  <div>
                    <label style="font-size: 0.85em; font-weight: 600;">Ciudad *</label>
                    <input type="text" id="ship-city" placeholder="Ej: Medellín" style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px;" required />
                  </div>
                  <div>
                    <label style="font-size: 0.85em; font-weight: 600;">Teléfono *</label>
                    <input type="tel" id="ship-phone" placeholder="Ej: 300 123 4567" style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px;" required />
                  </div>
                  <div>
                    <label style="font-size: 0.85em; font-weight: 600;">Código Postal</label>
                    <input type="text" id="ship-zip" placeholder="Ej: 050012" style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px;" />
                  </div>
                  <div style="grid-column: span 2;">
                    <label style="font-size: 0.85em; font-weight: 600;">Instrucciones Especiales</label>
                    <textarea id="ship-notes" placeholder="Ej: Dejar en portería" style="width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; resize: vertical; min-height: 60px;"></textarea>
                  </div>
                </div>
                <div style="display: flex; gap: 10px; margin-top: 15px;">
                  <button type="button" id="btn-cancel-new" style="padding: 10px 15px; border-radius: 6px; border: 1px solid #cbd5e1; background: white; cursor: pointer;">Cancelar</button>
                  <button type="submit" style="padding: 10px 15px; border-radius: 6px; border: none; background: #10b981; color: white; cursor: pointer; font-weight: bold;">Guardar Dirección</button>
                </div>
              </form>
            </div>
          </div>

          <div class="container-btn">
            <button type="button" id="continue-btn">Continuar al Pago <i class="fa fa-arrow-right"></i></button>
            <a href="/carrito" id="back-btn">Volver al Carrito</a>
          </div>
        </div>

        <div class="checkout-summary-container">
          <h3>Resumen del Pedido</h3>
          <div id="summary-items-list" class="summary-items-list">
          </div>
          <hr class="summary-divider" />
          <div class="summary-totals">
            <div class="summary-row">
              <span>Subtotal:</span>
              <span id="summary-subtotal">$0.00</span>
            </div>
            <div class="summary-row">
              <span>Costo de Envío:</span>
              <span id="summary-shipping">$0.00</span>
            </div>
            <hr class="summary-divider-light" />
            <div class="summary-row total-row">
              <span>Total Estimado:</span>
              <span id="summary-total">$0.00</span>
            </div>
          </div>
        </div>
      </div>
    </main>

    <footer>
        <p>&copy; 2026 Agro-Campo. Todos los derechos reservados.</p>
    </footer>
    
    <script src="../js/main.js"></script>
    <script>
      let cart = JSON.parse(localStorage.getItem("cart")) || [];
      const user = JSON.parse(localStorage.getItem("user"));
      let direcciones = [];
      let selectedId = null;

      if (!user) {
        window.location.href = '/login';
      }

      function renderOrderSummary() {
        const summaryList = document.getElementById("summary-items-list");
        if (!summaryList) return;
        if (cart.length === 0) {
          summaryList.innerHTML = '<p>Carrito vacío.</p>';
          return;
        }
        let subtotal = 0;
        cart.forEach(item => {
          subtotal += item.price * item.quantity;
          summaryList.innerHTML += `
            <div class="summary-item-card" style="display:flex; justify-content:space-between; margin-bottom:10px; font-size:0.9em;">
              <span>${item.quantity}x ${item.name}</span>
              <span>$${parseFloat(item.price * item.quantity).toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}</span>
            </div>
          `;
        });
        const shipping = subtotal > 50 ? 0.00 : 2.00;
        const total = subtotal + shipping;
        document.getElementById("summary-subtotal").textContent = `$${subtotal.toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
        document.getElementById("summary-shipping").textContent = shipping === 0 ? "Gratis" : `$${shipping.toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
        document.getElementById("summary-total").textContent = `$${total.toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
      }

      async function fetchDirecciones() {
        try {
          const res = await fetch(`/api/user/${user.idUser}/direcciones`, {
            headers: { 'Authorization': `Bearer ${user.token}` }
          });
          if (res.ok) {
            direcciones = await res.json();
            renderDirecciones();
          }
        } catch (e) {
          console.error(e);
        }
      }

      function renderDirecciones() {
        const container = document.getElementById('saved-addresses-container');
        if (direcciones.length === 0) {
          container.innerHTML = '<p style="color:#64748b; margin-bottom: 15px;">No tienes direcciones guardadas.</p>';
          document.getElementById('new-address-form').classList.add('active');
          return;
        }

        container.innerHTML = '';
        direcciones.forEach((dir, index) => {
          if (index === 0 && !selectedId) selectedId = dir.id_direccion;
          const isSelected = selectedId === dir.id_direccion;
          
          let fullAddr = `${dir.direccion_principal}, ${dir.ciudad}, ${dir.departamento}.`;
          if (dir.codigo_postal) fullAddr += ` CP: ${dir.codigo_postal}.`;
          fullAddr += ` Tel: ${dir.telefono}.`;
          if (dir.notas) fullAddr += ` Notas: ${dir.notas}`;

          container.innerHTML += `
            <div class="address-card ${isSelected ? 'selected' : ''}" onclick="selectAddress(${dir.id_direccion})">
              <input type="radio" class="address-radio" name="address" ${isSelected ? 'checked' : ''} />
              <div class="address-details">
                <div class="address-title">
                  <span><i class="fa fa-map-marker-alt" style="color:#ef4444; margin-right:5px;"></i> ${dir.titulo}</span>
                </div>
                <div class="address-text" id="text-dir-${dir.id_direccion}">${fullAddr}</div>
              </div>
            </div>
          `;
        });
      }

      window.selectAddress = function(id) {
        selectedId = id;
        renderDirecciones();
      }

      document.getElementById('btn-show-new-address').addEventListener('click', () => {
        document.getElementById('new-address-form').classList.add('active');
      });

      document.getElementById('btn-cancel-new').addEventListener('click', () => {
        if(direcciones.length > 0) {
          document.getElementById('new-address-form').classList.remove('active');
        }
      });

      document.getElementById('form-add-address').addEventListener('submit', async (e) => {
        e.preventDefault();
        const body = {
          titulo: document.getElementById('ship-title').value,
          direccion_principal: document.getElementById('ship-address').value,
          departamento: document.getElementById('ship-state').value,
          ciudad: document.getElementById('ship-city').value,
          telefono: document.getElementById('ship-phone').value,
          codigo_postal: document.getElementById('ship-zip').value,
          notas: document.getElementById('ship-notes').value
        };

        try {
          const res = await fetch(`/api/user/${user.idUser}/direcciones`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${user.token}`,
              'x-csrf-token': document.cookie.split('; ').find(row => row.startsWith('_csrf='))?.split('=')[1] // Aprox
            },
            body: JSON.stringify(body)
          });
          if (res.ok) {
            document.getElementById('form-add-address').reset();
            document.getElementById('new-address-form').classList.remove('active');
            fetchDirecciones();
          } else {
            alert('Error al guardar la dirección');
          }
        } catch (err) {
          console.error(err);
        }
      });

      document.getElementById('continue-btn').addEventListener('click', () => {
        if (cart.length === 0) return alert('Carrito vacío');
        if (!selectedId) return alert('Por favor selecciona o crea una dirección de envío.');
        
        const addressText = document.getElementById(`text-dir-${selectedId}`).textContent;
        localStorage.setItem("selectedShippingAddress", addressText);
        window.location.href = '/pago';
      });

      renderOrderSummary();
      fetchDirecciones();
    </script>
  </body>
</html>
