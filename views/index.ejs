    <!-- Script de Interacción Modal -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const modal = document.getElementById("product-detail-modal");
        const closeBtn = document.getElementById("close-product-modal");
        const qtyInput = document.getElementById("modal-qty-input");
        const minusBtn = document.getElementById("modal-qty-minus");
        const plusBtn = document.getElementById("modal-qty-plus");
        const modalAddBtn = document.getElementById("modal-btn-add");

        // A. Abrir modal con los triggers
        document.addEventListener("click", function(e) {
          const trigger = e.target.closest(".product-trigger") || e.target.closest(".btn-view-details");
          if (trigger) {
            const id = trigger.getAttribute("data-id");
            const nombre = trigger.getAttribute("data-nombre");
            const precio = parseFloat(trigger.getAttribute("data-precio"));
            const imagen = trigger.getAttribute("data-imagen");
            const descripcion = trigger.getAttribute("data-descripcion");

            const origin_db = trigger.getAttribute("data-origen") || "";
            const presentation_db = trigger.getAttribute("data-presentacion") || "";
            const care_db = trigger.getAttribute("data-cuidado") || "";
            const availability_db = trigger.getAttribute("data-disponibilidad") || "";

            // Asignar contenidos al modal
            document.getElementById("modal-product-image").src = imagen;
            document.getElementById("modal-product-image").alt = nombre;
            document.getElementById("modal-product-name").textContent = nombre;
            document.getElementById("modal-product-price").textContent = `$${precio.toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
            document.getElementById("modal-product-description").textContent = descripcion && descripcion !== 'null' ? descripcion : "Producto fresco y seleccionado de las mejores huertas agrícolas locales de El Carmen de Bolívar.";
            
            // Compilar especificaciones
            let origin = origin_db && origin_db !== 'null' ? origin_db : "El Carmen de Bolívar";
            let category = "Orgánico"; // Conservado de nombre / UI
            let presentation = presentation_db && presentation_db !== 'null' ? presentation_db : "Por unidad";
            let care = care_db && care_db !== 'null' ? care_db : "100% natural, sin químicos sintéticos";
            
            const lowerName = nombre.toLowerCase();
            if (lowerName.includes("semilla")) {
              category = "Semillas";
            } else if (lowerName.includes("abono") || lowerName.includes("fertilizante") || lowerName.includes("tierra")) {
              category = "Insumos";
            } else if (lowerName.includes("herramienta") || lowerName.includes("pala") || lowerName.includes("machete") || lowerName.includes("rastrillo")) {
              category = "Herramientas";
            } else if (lowerName.includes("leche") || lowerName.includes("queso") || lowerName.includes("suero") || lowerName.includes("yogur")) {
              category = "Lácteos";
            } else if (lowerName.includes("concentrado") || lowerName.includes("comida") || lowerName.includes("purina")) {
              category = "Nutrición Animal";
            }
            
            document.getElementById("modal-product-tag").textContent = category;
            document.getElementById("modal-product-origin").textContent = origin;
            document.getElementById("modal-product-presentation").textContent = presentation;
            document.getElementById("modal-product-care").textContent = care;

            // Manejo de disponibilidad/stock
            const availText = document.getElementById("modal-product-availability");
            const availIcon = document.getElementById("modal-product-availability-icon");
            const maxQty = parseInt(availability_db, 10);

            let isOutOfStock = false;
            let finalAvailabilityText = "En Stock (Despacho Inmediato)";

            if (availability_db && (availability_db.toLowerCase().includes("sin") || availability_db.toLowerCase().includes("agotado"))) {
              isOutOfStock = true;
            } else if (!isNaN(maxQty)) {
              if (maxQty <= 0) {
                isOutOfStock = true;
              } else {
                finalAvailabilityText = `${maxQty} unidades disponibles`;
              }
            } else if (availability_db && availability_db !== 'null') {
              finalAvailabilityText = availability_db;
            }

            if (isOutOfStock) {
              availText.textContent = "Sin unidades disponibles";
              availText.style.color = "#ef4444";
              if (availIcon) {
                availIcon.className = "fa fa-circle-xmark";
                availIcon.style.color = "#ef4444";
              }
              // Deshabilitar botón de añadir
              modalAddBtn.disabled = true;
              modalAddBtn.style.backgroundColor = "#94a3b8";
              modalAddBtn.style.boxShadow = "none";
              modalAddBtn.style.cursor = "not-allowed";
              modalAddBtn.innerHTML = '<i class="fa fa-ban"></i> Agotado';
              qtyInput.value = 0;
            } else {
              if (availText) {
                if (!isNaN(maxQty) && maxQty > 0 && maxQty <= 5) {
                   availText.innerHTML = `Pocas unidades disponibles (${maxQty})`;
                   availText.style.color = "#f59e0b"; // Naranja
                } else {
                   availText.textContent = finalAvailabilityText;
                   availText.style.color = "#166534"; // Verde
                }
              }
              if (availIcon) {
                if (!isNaN(maxQty) && maxQty > 0 && maxQty <= 5) {
                   availIcon.className = "fa fa-triangle-exclamation";
                   availIcon.style.color = "#f59e0b"; // Naranja
                } else {
                   availIcon.className = "fa fa-circle-check";
                   availIcon.style.color = "#10b981"; // Verde
                }
              }
              // Habilitar botón de añadir
              modalAddBtn.disabled = false;
              modalAddBtn.style.backgroundColor = "#10b981";
              modalAddBtn.style.boxShadow = "0 4px 10px rgba(16,185,129,0.2)";
              modalAddBtn.style.cursor = "pointer";
              modalAddBtn.innerHTML = '<i class="fa fa-cart-plus"></i> Añadir al Carrito';
              qtyInput.value = 1;
            }
            
            // Guardar datos temporales en el botón del modal
            modalAddBtn.setAttribute("data-id", id);
            modalAddBtn.setAttribute("data-nombre", nombre);
            modalAddBtn.setAttribute("data-precio", precio);
            modalAddBtn.setAttribute("data-imagen", imagen);
            modalAddBtn.setAttribute("data-presentacion", presentation);
            modalAddBtn.setAttribute("data-disponibilidad", availability_db);

            // Mostrar modal
            modal.style.display = "flex";
          }
        });

        // B. Cerrar modal al hacer clic en (X) o fuera del modal
        if (closeBtn) {
          closeBtn.addEventListener("click", () => {
            modal.style.display = "none";
          });
        }
        
        window.addEventListener("click", (e) => {
          if (e.target === modal) {
            modal.style.display = "none";
          }
        });

        // C. Manejo del contador (+ / -)
        if (minusBtn && qtyInput) {
          minusBtn.addEventListener("click", () => {
            const availText = document.getElementById("modal-product-availability");
            if (availText && availText.textContent.includes("Sin unidades")) return;
            let currentVal = parseInt(qtyInput.value) || 1;
            if (currentVal > 1) {
              qtyInput.value = currentVal - 1;
            }
          });
        }
        
        if (plusBtn && qtyInput) {
          plusBtn.addEventListener("click", () => {
            const availText = document.getElementById("modal-product-availability");
            if (availText && availText.textContent.includes("Sin unidades")) return;
            const maxQty = parseInt(modalAddBtn.getAttribute("data-disponibilidad"), 10);
            let currentVal = parseInt(qtyInput.value) || 1;
            if (!isNaN(maxQty) && currentVal >= maxQty) {
              alert(`Lo sentimos, no puedes agregar más de ${maxQty} unidades de este producto.`);
              return;
            }
            qtyInput.value = currentVal + 1;
          });
        }

        // D. Agregar al carrito la cantidad seleccionada en el modal
        if (modalAddBtn) {
          modalAddBtn.addEventListener("click", () => {
            const productId = modalAddBtn.getAttribute("data-id");
            const productName = modalAddBtn.getAttribute("data-nombre");
            const productPrice = parseFloat(modalAddBtn.getAttribute("data-precio"));
            const productImg = modalAddBtn.getAttribute("data-imagen");
            const productPresentacion = modalAddBtn.getAttribute("data-presentacion") || "Unidad";
            const productDisponibilidad = modalAddBtn.getAttribute("data-disponibilidad");
            const maxQty = parseInt(productDisponibilidad, 10);
            const quantity = parseInt(qtyInput.value) || 1;

            if (quantity <= 0) return;

            let cart = JSON.parse(localStorage.getItem("cart")) || [];
            const existingItem = cart.find((item) => item.id === productId);

            if (!isNaN(maxQty)) {
              const currentQtyInCart = existingItem ? existingItem.quantity : 0;
              if (currentQtyInCart + quantity > maxQty) {
                alert(`Lo sentimos, no puedes agregar esa cantidad al carrito. Ya tienes ${currentQtyInCart} unidades en tu pedido y el stock máximo es de ${maxQty}.`);
                return;
              }
            }

            if (existingItem) {
               existingItem.quantity += quantity;
            } else {
               cart.push({
                 id: productId,
                 name: productName,
                 price: productPrice,
                 img: productImg,
                 quantity: quantity,
                 presentacion: productPresentacion
               });
            }

            // Guardar en LocalStorage y sincronizar
            localStorage.setItem("cart", JSON.stringify(cart));
            
            // Actualizar contadores globales del header
            const cartCount = document.querySelectorAll(".cart-count");
            const totalItems = cart.reduce((total, item) => total + item.quantity, 0);
            cartCount.forEach((element) => {
              element.textContent = totalItems;
            });

            // Ocultar modal
            modal.style.display = "none";

            // Disparar la hermosa notificación flotante de Agro-Campo
            const notification = document.createElement("div");
            notification.className = "notification show";
            notification.textContent = `${quantity}x ${productName} añadido al carrito`;
            document.body.appendChild(notification);
            setTimeout(() => {
              notification.classList.remove("show");
              setTimeout(() => notification.remove(), 500);
            }, 2200);
          });
        }
      });
    </script>
  </body>
  <!-- Loader global -->
<div id="global-loader" style="display:none;">
  <div class="loader-backdrop"></div>
  <div class="loader-spinner">
    <i id="loader-icon" class="fa fa-spinner fa-spin fa-3x"></i>
    <p id="loader-text">Cargando...</p>
  </div>
</div>
</html>
